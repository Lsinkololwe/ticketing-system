{
  "mcpServers": {
    "mongodb": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mongodb-mcp-server@latest",
        "--readOnly"
      ],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "mongodb://app_user:app_password@localhost:27017/ticketing?authSource=admin"
      }
    }
  }
}
