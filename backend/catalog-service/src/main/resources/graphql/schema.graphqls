# ============================================================================
# SECTION 13: ROOT QUERY TYPE
# ============================================================================
#
# Queries are tagged by their intended audience:
# - (no tag) = Public - available to all clients (mobile, web, admin)
# - "mobile" = Mobile app specific features
# - "organizer" = Organizer dashboard features
# - "admin" = Platform administrator features only
# - "internal" = Service-to-service communication only
#
type Query {
    # ========================================================================
    # EVENT DISCOVERY QUERIES (PUBLIC - For all consumers)
    # ========================================================================
    # These queries are used by mobile apps and web to browse/search events.
    # No tags needed - available to all clients.

    # Get single event by ID - PUBLIC
    event(id: ID!): Event

    # Combined discovery with all filters - PRIMARY PUBLIC QUERY
    # This is the main query for event discovery on mobile and web
    discoverEvents(filter: EventDiscoveryFilterInput!, pagination: CursorPaginationInput): EventConnection!

    # Cursor pagination queries (mobile/infinite scroll) - PUBLIC
    # Used by mobile apps for infinite scroll event lists
    publishedEventsCursorPagination(pagination: CursorPaginationInput): EventConnection!
    searchEventsCursorPagination(query: String!, pagination: CursorPaginationInput): EventConnection!
    upcomingEventsCursorPagination(pagination: CursorPaginationInput): EventConnection!
    eventsByCategoryCursorPagination(categoryId: String!, pagination: CursorPaginationInput): EventConnection!
    eventsByCityCursorPagination(city: String!, pagination: CursorPaginationInput): EventConnection!
    eventsByDateRangeCursorPagination(startDate: DateTime!, endDate: DateTime!, pagination: CursorPaginationInput): EventConnection!
    eventsByPriceRangeCursorPagination(minPrice: BigDecimal, maxPrice: BigDecimal, pagination: CursorPaginationInput): EventConnection!
    featuredEventsCursorPagination(pagination: CursorPaginationInput): EventConnection!
    freeEventsCursorPagination(pagination: CursorPaginationInput): EventConnection!

    # Organizer's public events - available to see organizer's profile page
    eventsByOrganizerCursorPagination(organizerId: String!, pagination: CursorPaginationInput): EventConnection!

    # ========================================================================
    # OFFSET PAGINATION QUERIES (ADMIN/ORGANIZER - Dashboard tables)
    # ========================================================================
    # Offset pagination is used for admin dashboard tables with page numbers.
    # These are not needed by mobile consumers.

    publishedEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    searchEventsOffsetPagination(query: String!, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    upcomingEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    eventsByCategoryOffsetPagination(categoryId: String!, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    eventsByCityOffsetPagination(city: String!, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    eventsByDateRangeOffsetPagination(startDate: DateTime!, endDate: DateTime!, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    eventsByPriceRangeOffsetPagination(minPrice: BigDecimal, maxPrice: BigDecimal, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    featuredEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    freeEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    eventsByOrganizerOffsetPagination(organizerId: String!, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")

    # ========================================================================
    # EVENT COUNT QUERIES (ADMIN - Dashboard statistics)
    # ========================================================================
    # Count queries for admin dashboard statistics cards

    eventCount: Int! @auth(requires: ADMIN) @tag(name: "admin")
    eventCountByOrganizer(organizerId: String!): Int! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    eventCountByCategory(categoryId: String!): Int! @auth(requires: ADMIN) @tag(name: "admin")
    eventCountByCity(city: String!): Int! @auth(requires: ADMIN) @tag(name: "admin")
    eventCountByStatus(status: EventStatus!): Int! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # EVENT STATISTICS QUERIES (ORGANIZER/ADMIN)
    # ========================================================================
    # Per-event statistics - organizers can see their own event stats

    # Per-event ticket statistics - for organizer dashboard
    eventStatistics(eventId: ID!): EventTicketStatistics @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    ticketTierStatistics(eventId: ID!, tierId: ID!): TicketTierStats @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")

    # Platform-wide event statistics - ADMIN ONLY
    eventStats: EventStats! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # ADMIN EVENT MANAGEMENT QUERIES
    # ========================================================================
    # These queries are for managing events - approval workflow, drafts, etc.

    # General event list with filters - ADMIN dashboard
    eventsOffsetPagination(filter: EventFilterInput, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # Draft events - Organizer sees their own, admin sees all
    draftEventsOffsetPagination(organizerId: String!, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")

    # Approval workflow queries - ADMIN ONLY
    pendingApprovalEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    overdueApprovalEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    approvedNotPublishedEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    eventsByStatusOffsetPagination(status: EventStatus!, pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    cancelledEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    completedEventsOffsetPagination(pagination: OffsetPaginationInput): EventOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # Cursor versions for mobile admin app (if needed)
    eventsCursorPagination(filter: EventFilterInput, pagination: CursorPaginationInput): EventConnection! @auth(requires: ADMIN) @tag(name: "admin")
    draftEventsCursorPagination(organizerId: String!, pagination: CursorPaginationInput): EventConnection! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    pendingApprovalEventsCursorPagination(pagination: CursorPaginationInput): EventConnection! @auth(requires: ADMIN) @tag(name: "admin")
    overdueApprovalEventsCursorPagination(pagination: CursorPaginationInput): EventConnection! @auth(requires: ADMIN) @tag(name: "admin")
    approvedNotPublishedEventsCursorPagination(pagination: CursorPaginationInput): EventConnection! @auth(requires: ADMIN) @tag(name: "admin")
    eventsByStatusCursorPagination(status: EventStatus!, pagination: CursorPaginationInput): EventConnection! @auth(requires: ADMIN) @tag(name: "admin")
    cancelledEventsCursorPagination(pagination: CursorPaginationInput): EventConnection! @auth(requires: ADMIN) @tag(name: "admin")
    completedEventsCursorPagination(pagination: CursorPaginationInput): EventConnection! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # LOCATION QUERIES
    # ========================================================================

    location(id: ID!): Location

    # Cursor pagination (mobile/infinite scroll)
    locationsCursorPagination(pagination: CursorPaginationInput): LocationConnection!
    locationsByCityCursorPagination(city: String!, pagination: CursorPaginationInput): LocationConnection!
    locationsByCountryCursorPagination(country: String!, pagination: CursorPaginationInput): LocationConnection!
    # PUBLIC - Mobile search with cursor pagination for infinite scroll
    searchLocationsCursorPagination(query: String!, pagination: CursorPaginationInput): LocationConnection!
    # PUBLIC - Mobile nearby locations with cursor pagination
    locationsNearbyCursorPagination(input: NearbyLocationInput!, pagination: CursorPaginationInput): LocationConnection!


    # ========================================================================
    # CITY QUERIES
    # Cities are reference data used for filtering - public for event discovery
    # ========================================================================

    # PUBLIC - Single city lookup for event location display
    city(id: ID!): City

    # ---------------------------------------------------------------------------
    # PUBLIC CITY QUERIES - Cursor pagination for mobile infinite scroll
    # Cities are public reference data needed for location-based filtering
    # ---------------------------------------------------------------------------
    citiesCursorPagination(pagination: CursorPaginationInput): CityConnection!
    citiesByProvinceCursorPagination(provinceId: String!, pagination: CursorPaginationInput): CityConnection!
    citiesByCountryCursorPagination(country: String!, pagination: CursorPaginationInput): CityConnection!
    searchCitiesCursorPagination(query: String!, pagination: CursorPaginationInput): CityConnection!

    # ---------------------------------------------------------------------------
    # ADMIN CITY QUERIES - Offset pagination for admin dashboard tables
    # Only platform admins manage city reference data
    # ---------------------------------------------------------------------------
    citiesOffsetPagination(pagination: OffsetPaginationInput): CityOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    citiesByProvinceOffsetPagination(provinceId: String!, pagination: OffsetPaginationInput): CityOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    citiesByCountryOffsetPagination(country: String!, pagination: OffsetPaginationInput): CityOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    searchCitiesOffsetPagination(query: String!, pagination: OffsetPaginationInput): CityOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # PUBLIC - Used for filtering events to cities that have events
    citiesWithEvents: [City!]!

    # ========================================================================
    # PROVINCE QUERIES
    # Provinces are reference data used for regional filtering - public for discovery
    # ========================================================================

    # PUBLIC - Single province lookup for regional display
    province(id: ID!): Province

    # ---------------------------------------------------------------------------
    # PUBLIC PROVINCE QUERIES - Cursor pagination for mobile infinite scroll
    # Provinces are public reference data needed for regional filtering
    # ---------------------------------------------------------------------------
    provincesCursorPagination(pagination: CursorPaginationInput): ProvinceConnection!
    provincesByCountryCursorPagination(country: String!, pagination: CursorPaginationInput): ProvinceConnection!
    searchProvincesCursorPagination(query: String!, pagination: CursorPaginationInput): ProvinceConnection!

    # ---------------------------------------------------------------------------
    # ADMIN PROVINCE QUERIES - Offset pagination for admin dashboard tables
    # Only platform admins manage province reference data
    # ---------------------------------------------------------------------------
    provincesOffsetPagination(pagination: OffsetPaginationInput): ProvinceOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    provincesByCountryOffsetPagination(country: String!, pagination: OffsetPaginationInput): ProvinceOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    searchProvincesOffsetPagination(query: String!, pagination: OffsetPaginationInput): ProvinceOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # EVENT CATEGORY QUERIES
    # Categories are essential for event discovery - public for filtering
    # ========================================================================

    # PUBLIC - Single category lookup for event categorization display
    eventCategory(id: ID!): EventCategory

    # ---------------------------------------------------------------------------
    # PUBLIC CATEGORY QUERIES - Cursor pagination for mobile infinite scroll
    # Categories are public reference data needed for event filtering/browsing
    # ---------------------------------------------------------------------------
    eventCategoriesCursorPagination(pagination: CursorPaginationInput): EventCategoryConnection!
    activeEventCategoriesCursorPagination(pagination: CursorPaginationInput): EventCategoryConnection!
    searchEventCategoriesCursorPagination(query: String!, pagination: CursorPaginationInput): EventCategoryConnection!

    # ---------------------------------------------------------------------------
    # ADMIN CATEGORY QUERIES - Offset pagination for admin dashboard tables
    # Only platform admins manage category reference data
    # ---------------------------------------------------------------------------
    eventCategoriesOffsetPagination(pagination: OffsetPaginationInput): EventCategoryOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    activeEventCategoriesOffsetPagination(pagination: OffsetPaginationInput): EventCategoryOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    searchEventCategoriesOffsetPagination(query: String!, pagination: OffsetPaginationInput): EventCategoryOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # PUBLIC - Popular categories for mobile home screen and event discovery
    popularCategories(limit: Int = 10): [EventCategory!]!

    # ========================================================================
    # PLATFORM CONFIGURATION QUERIES (Admin Only)
    # Platform settings for SLA, escalation, and notification configuration
    # ========================================================================

    # ADMIN - Get current platform configuration
    platformConfiguration: PlatformConfiguration! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # APPROVAL TIMELINE QUERIES
    # Approval workflows are admin-only - platform administrators manage event approvals
    # Organizers can see their own approval status via event.status field
    # ========================================================================

    # ADMIN - View approval timeline for any event (approval workflow visibility)
    approvalTimeline(eventId: String!): ApprovalTimeline @auth(requires: ADMIN) @tag(name: "admin")

    # ---------------------------------------------------------------------------
    # ADMIN APPROVAL QUERIES - Offset pagination for admin dashboard tables
    # Approval workflow management is admin-only functionality
    # ---------------------------------------------------------------------------
    approvalTimelinesOffsetPagination(filter: ApprovalTimelineFilterInput, pagination: OffsetPaginationInput): ApprovalTimelineOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    approvalTimelinesByOrganizerOffsetPagination(organizerId: String!, pagination: OffsetPaginationInput): ApprovalTimelineOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    pendingApprovalTimelinesOffsetPagination(pagination: OffsetPaginationInput): ApprovalTimelineOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")
    overdueApprovalTimelinesOffsetPagination(pagination: OffsetPaginationInput): ApprovalTimelineOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Cursor pagination for approval timeline lists (if admin uses mobile)
    approvalTimelinesCursorPagination(filter: ApprovalTimelineFilterInput, pagination: CursorPaginationInput): ApprovalTimelineConnection! @auth(requires: ADMIN) @tag(name: "admin")
    approvalTimelinesByOrganizerCursorPagination(organizerId: String!, pagination: CursorPaginationInput): ApprovalTimelineConnection! @auth(requires: ADMIN) @tag(name: "admin")
    pendingApprovalTimelinesCursorPagination(pagination: CursorPaginationInput): ApprovalTimelineConnection! @auth(requires: ADMIN) @tag(name: "admin")
    overdueApprovalTimelinesCursorPagination(pagination: CursorPaginationInput): ApprovalTimelineConnection! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # APPROVAL ESCALATION QUERIES (Admin Only)
    # ========================================================================

    # ADMIN - Get specific escalation by ID
    approvalEscalation(id: ID!): ApprovalEscalation @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Get active escalations (offset pagination for dashboard)
    activeEscalationsOffsetPagination(pagination: OffsetPaginationInput): ApprovalEscalationOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Get escalations assigned to current admin (adminId from JWT - OWASP A01:2021)
    myEscalationsOffsetPagination(pagination: OffsetPaginationInput): ApprovalEscalationOffsetPage! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Cursor pagination for escalations (mobile admin)
    activeEscalationsCursorPagination(pagination: CursorPaginationInput): ApprovalEscalationConnection! @auth(requires: ADMIN) @tag(name: "admin")
    # adminId extracted from JWT - OWASP A01:2021 compliance
    myEscalationsCursorPagination(pagination: CursorPaginationInput): ApprovalEscalationConnection! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # APPROVAL STATISTICS QUERIES (Admin Only)
    # ========================================================================

    # ADMIN - Get approval workflow statistics for dashboard
    approvalStats: ApprovalStats! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # TICKET TIER QUERIES
    # Ticket tiers are essential for the ticket purchase flow
    # PUBLIC - Needed by mobile app for displaying ticket options
    # ========================================================================

    # PUBLIC - Single ticket tier lookup for purchase flow
    ticketTier(id: ID!): TicketTier
    # ORGANIZER/ADMIN - Include hidden tiers (draft tiers not visible to customers)
    # Organizers need to see all tiers including hidden ones when managing events
    eventTicketTiers(eventId: ID!, includeHidden: Boolean = false): [TicketTier!]! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    # PUBLIC - Available tiers for customer ticket purchase (mobile app)
    availableTicketTiers(eventId: ID!): [TicketTier!]!

    # ========================================================================
    # EVENT LIFECYCLE QUERIES
    # Lifecycle management is for event management (organizers and admins)
    # Customers don't need to see internal lifecycle/status transition logic
    # ========================================================================

    # ORGANIZER/ADMIN - View event lifecycle state and history
    eventLifecycle(eventId: String!): EventLifecycle @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    # ORGANIZER/ADMIN - Determine valid status transitions for workflow UI
    allowedStatusTransitions(eventId: String!): [EventStatus!]! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")

    # ========================================================================
    # EXPORT QUERIES
    # Export functionality is admin-only for platform reporting
    # Organizers get their own reporting via separate organizer dashboard queries
    # ========================================================================

    # ADMIN - Export single event data for compliance/reporting
    exportEventData(eventId: ID!, format: ExportFormat!): ReportExport! @auth(requires: ADMIN) @tag(name: "admin")
    # ADMIN - Export filtered events report for platform analytics
    exportEventsReport(filter: EventFilterInput!, format: ExportFormat!): ReportExport! @auth(requires: ADMIN) @tag(name: "admin")
}

# ============================================================================
# SECTION 14: ROOT MUTATION TYPE
# Tags indicate which clients should include these mutations in their operations:
# - organizer: Organizer dashboard for event management
# - admin: Platform administrator operations
# - mobile: Consumer mobile app actions
# ============================================================================
type Mutation {
    # ========================================================================
    # EVENT MUTATIONS
    # Organizers create and manage their own events
    # Admin can also perform these operations for platform management
    # ========================================================================

    # ORGANIZER - Core event CRUD operations
    # NOTE: organizerId is extracted from JWT authentication, not passed as parameter
    # This prevents OWASP A01:2021 Broken Access Control vulnerabilities
    createEvent(input: CreateEventInput!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    updateEvent(id: ID!, input: UpdateEventInput!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    deleteEvent(id: ID!): DeleteMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    # ORGANIZER - Event publishing workflow
    publishEvent(id: ID!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    unpublishEvent(id: ID!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    # ORGANIZER - Event cancellation (triggers refund workflows)
    cancelEvent(id: ID!, input: EventCancellationInput!): EventCancellationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    # INTERNAL - Auto-completion triggered by system when event date passes
    completeEvent(id: ID!): EventMutationResponse! @auth(requires: INTERNAL) @tag(name: "internal")
    # ORGANIZER - Duplicate event for recurring events workflow
    duplicateEvent(eventId: ID!, newTitle: String!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    # ORGANIZER - Capacity and accessibility management
    updateEventCapacity(eventId: ID!, newCapacity: Int!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    updateEventAccessibility(eventId: ID!, input: EventAccessibilityInput!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    # ADMIN - Featured events are platform decisions (homepage promotion)
    featureEvent(eventId: ID!, featured: Boolean!): EventMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # PLATFORM CONFIGURATION MUTATIONS (Admin Only)
    # ========================================================================

    # ADMIN - Update platform configuration (SLA settings, escalation, notifications)
    updatePlatformConfiguration(input: UpdatePlatformConfigurationInput!): PlatformConfigurationMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # EVENT APPROVAL MUTATIONS
    # Approval workflow: Organizers submit, Admins approve/reject
    # ========================================================================

    # ORGANIZER - Submit event for platform review
    # NOTE: organizerId is extracted from JWT authentication
    submitEventForApproval(eventId: ID!): EventMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    # ADMIN - Approval decisions are admin-only platform operations
    # NOTE: reviewerId/adminId extracted from JWT authentication (OWASP A01:2021 compliance)
    approveEvent(eventId: ID!, comments: String): EventMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    rejectEvent(eventId: ID!, comments: String!): EventMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    requestEventChanges(eventId: ID!, comments: String!): EventMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Reviewer assignment for approval workflow
    assignEventReviewer(input: AssignReviewerInput!): ApprovalTimelineMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    unassignEventReviewer(eventId: ID!, reason: String): ApprovalTimelineMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Add internal comment to approval timeline (without status change)
    # NOTE: adminId extracted from JWT authentication (OWASP A01:2021 compliance)
    addApprovalComment(eventId: ID!, comment: String!, isInternal: Boolean = true): ApprovalTimelineMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # ESCALATION MUTATIONS (Admin Only)
    # NOTE: All adminId parameters extracted from JWT authentication (OWASP A01:2021 compliance)
    # ========================================================================

    # ADMIN - Acknowledge an escalation
    acknowledgeEscalation(escalationId: ID!, notes: String): ApprovalEscalationMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Resolve an escalation (must also approve/reject/request changes)
    resolveEscalation(input: ResolveEscalationInput!): ApprovalEscalationMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Manually trigger escalation (for testing or manual override)
    triggerManualEscalation(eventId: ID!, reason: String!, escalateTo: String!): ApprovalEscalationMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # EVENT REMINDER MUTATIONS
    # Platform sends reminders to organizers - admin operation
    # ========================================================================

    # ADMIN - Platform nudges organizers to publish their events
    sendEventPublishReminder(eventId: ID!, triggeredBy: String!): EventMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    sendBulkEventPublishReminders(eventIds: [ID!]!, triggeredBy: String!): BulkReminderResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # TICKET TIER MUTATIONS
    # Organizers manage ticket tiers for their events
    # ========================================================================

    # ORGANIZER - Ticket tier CRUD for event pricing structure
    createTicketTier(eventId: ID!, input: CreateTicketTierInput!): TierMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    updateTicketTier(tierId: ID!, input: UpdateTicketTierInput!): TierMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    deleteTicketTier(tierId: ID!): DeleteMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    reorderTicketTiers(eventId: ID!, tierIds: [ID!]!): [TicketTier!]! @auth(requires: ORGANIZER) @tag(name: "organizer")
    activateTicketTier(tierId: ID!): TierMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    deactivateTicketTier(tierId: ID!): TierMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")


    # ========================================================================
    # EVENT CATEGORY MUTATIONS
    # Platform manages category reference data - admin only
    # ========================================================================

    # ADMIN - Category CRUD for platform taxonomy
    createEventCategory(input: CreateEventCategoryInput!): CategoryMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    updateEventCategory(id: ID!, input: UpdateEventCategoryInput!): CategoryMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    deleteEventCategory(id: ID!): DeleteMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    activateEventCategory(id: ID!): CategoryMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    deactivateEventCategory(id: ID!): CategoryMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # PROVINCE MUTATIONS
    # Platform manages province reference data - admin only
    # ========================================================================

    # ADMIN - Province CRUD for regional data management
    createProvince(input: CreateProvinceInput!): ProvinceMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    updateProvince(id: ID!, input: UpdateProvinceInput!): ProvinceMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    deleteProvince(id: ID!): DeleteMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # CITY MUTATIONS
    # Platform manages city reference data - admin only
    # ========================================================================

    # ADMIN - City CRUD for geographic reference data
    createCity(input: CreateCityInput!): CityMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    updateCity(id: ID!, input: UpdateCityInput!): CityMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    deleteCity(id: ID!): DeleteMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
}

