# ============================================================================
# CATALOG SERVICE - GraphQL Federation 2 Subgraph Schema
# ============================================================================
#
# This service is the OWNER of Event and Category entities.
# It manages the event catalog - what events exist, where they are, and
# their categorization. Location is a simple embedded type for event addresses.
#
# FEDERATION CONCEPTS USED:
# - @key: Marks Event as a federated entity
# - @shareable: Allows Booking Service to also resolve certain fields
# - @tag: Marks fields/types for client-specific code generation
# - Entity stubs: We define User stub to reference Identity Service's User
#
# OWNERSHIP:
# - Event (primary owner)
# - EventCategory, Province, City (exclusive)
# - TicketTier (exclusive)
# - Location (simple type, embedded in Event)
#
# REFERENCES:
# - User (owned by Identity Service) - referenced via organizerId
#
# ============================================================================
# CLIENT-SPECIFIC TAGGING STRATEGY
# ============================================================================
#
# We use @tag directives to document which clients should use which fields.
# This enables operation-based code generation where each frontend only
# generates types for the operations it actually uses.
#
# TAG CATEGORIES:
# - (no tag)     = Public/shared - all clients can use
# - "mobile"     = Mobile app consumer features (Expo/React Native)
# - "organizer"  = Event organizer dashboard features (Next.js)
# - "admin"      = Platform administrator features only
# - "internal"   = Service-to-service communication (not for clients)
#
# TAGGING RULES:
# 1. Fields without tags are considered public (available to all)
# 2. Tags are additive - multiple tags mean multiple audiences
# 3. Queries/mutations inherit tagging from their use case
# 4. Statistics and reporting types are typically admin-only
# 5. Approval workflow fields/operations are admin-only
#
# ============================================================================
# SCHEMA ORGANIZATION:
# 1. Federation directives & Scalars
# 2. Enums
# 3. Entity stubs
# 4. Primary types (Event, Location)
# 5. Supporting types (TicketTier, EventCategory, etc.)
# 6. Statistics types
# 7. Pagination types
# 8. Input types
# 9. Mutation response types (consolidated)
# 10. Subscription payload types
# 11. Query type (bottom)
# 12. Mutation type (bottom)
# 13. Subscription type (very bottom)
#
# ============================================================================

# ============================================================================
# SECTION 1: FEDERATION 2 SCHEMA EXTENSION
# ============================================================================
#
# We import @tag directive to enable client-specific schema filtering.
# This allows Apollo GraphOS Contracts or operation-based codegen to
# generate optimized types for each frontend client.
#
extend schema @link(
    url: "https://specs.apollo.dev/federation/v2.9",
    import: ["@key", "@shareable", "@external", "@requires", "@provides", "@extends", "@inaccessible", "@tag"]
)

# ============================================================================
# SECTION 1.1: AUTHORIZATION DIRECTIVE
# ============================================================================
# Role enum and @auth directive are defined in shared-library/auth.graphqls
# and automatically loaded. Use @auth(requires: ROLE) on operations.
# ============================================================================

# ============================================================================
# SECTION 2: CUSTOM SCALARS
# ============================================================================
scalar DateTime
scalar BigDecimal
scalar JSON

# ============================================================================
# SECTION 3: ENUMS
# ============================================================================

# Event lifecycle status - controls what actions are available
enum EventStatus {
    DRAFT              # Initial state, not visible to public
    PENDING_REVIEW     # Submitted for admin review
    CHANGES_REQUESTED  # Admin requested changes
    APPROVED           # Approved but not yet published
    PUBLISHED          # Live and visible to public
    CANCELLED          # Event cancelled
    COMPLETED          # Event has ended
}

# Ticket category enum (shared value type with Booking Service)
enum TicketCategory {
    GENERAL
    PRE_SALE
    VIP
    VVIP
    PREMIUM
    EARLY_BIRD
    STUDENT
    SENIOR
    GROUP
    CORPORATE
    SPONSOR
    FREE
}

# Pagination sort direction
enum SortDirection {
    ASC
    DESC
}


# Export format options
enum ExportFormat {
    CSV
    PDF
    EXCEL
    JSON
}

# Approval action types for timeline tracking
enum ApprovalAction {
    SUBMITTED              # Organizer submitted event for review
    ASSIGNED               # Event assigned to reviewer
    VIEWED                 # Reviewer viewed event details
    APPROVED               # Event approved
    REJECTED               # Event rejected (final)
    CHANGES_REQUESTED      # Reviewer requested changes
    RESUBMITTED            # Organizer resubmitted after changes
    ESCALATED              # Auto-escalated due to SLA breach
    ESCALATION_RESOLVED    # Escalation was handled
    COMMENT_ADDED          # Internal comment added
}

# Escalation status
enum EscalationStatus {
    PENDING                # Escalation triggered, not yet handled
    ACKNOWLEDGED           # Senior admin acknowledged
    RESOLVED               # Escalation resolved
    EXPIRED                # Escalation expired without action
}

# Notification channel for approval workflow
enum ApprovalNotificationChannel {
    EMAIL
    IN_APP
    BOTH
}

# Notification type for approval workflow
enum ApprovalNotificationType {
    SUBMISSION_RECEIVED    # Organizer: your event was submitted
    REVIEW_ASSIGNED        # Admin: event assigned to you
    APPROVAL_GRANTED       # Organizer: your event was approved
    REJECTION_ISSUED       # Organizer: your event was rejected
    CHANGES_REQUESTED      # Organizer: changes requested
    ESCALATION_TRIGGERED   # Senior Admin: SLA breach escalation
    REMINDER_PENDING       # Admin: reminder for pending review
    SLA_WARNING            # Admin: approaching SLA deadline
}

# ============================================================================
# SECTION 4: ENTITY STUBS (Owned by other services)
# ============================================================================

# User stub - owned by Identity Service
type User @key(fields: "id", resolvable: false) {
    id: ID!
}

# Organization stub - owned by Identity Service
# Events belong to organizations, enabling team-based access control
type Organization @key(fields: "id", resolvable: false) {
    id: ID!
}

# ============================================================================
# SECTION 5: PRIMARY TYPES
# ============================================================================

# ------------------------------
# EVENT (Primary Entity)
# ------------------------------
# The Event type is the core entity for event discovery. Most fields are public
# for consumers browsing events. Organizer-specific fields are tagged for
# dashboard use, and approval workflow fields are admin-only.
#
type Event @key(fields: "id") {
    id: ID!

    # ─────────────────────────────────────────────────────────────────────────
    # PUBLIC FIELDS - Available to all clients (mobile, web, admin)
    # These fields are needed for event discovery and display
    # ─────────────────────────────────────────────────────────────────────────

    # Basic event information - PUBLIC
    title: String! @shareable
    description: String!
    category: EventCategory
    categoryId: String
    eventDateTime: DateTime! @shareable
    endDateTime: DateTime!

    # Location information - PUBLIC (where is the event?)
    location: Location
    locationId: String
    locationName: String @shareable
    locationAddress: String @shareable
    cityName: String @shareable

    # ─────────────────────────────────────────────────────────────────────────
    # ORGANIZER FIELDS - For organizer dashboards and admin portals
    # These fields identify who created the event and their contact info
    # ─────────────────────────────────────────────────────────────────────────

    # Organizer reference - needed by organizer dashboard and admin
    organizer: User @tag(name: "organizer") @tag(name: "admin")
    organizerId: String! @shareable @tag(name: "organizer") @tag(name: "admin")

    # Organization that owns this event (for team-based access control)
    # Team members of this organization can manage this event based on their roles
    organization: Organization @tag(name: "organizer") @tag(name: "admin")
    organizationId: String @tag(name: "organizer") @tag(name: "admin")

    # Public organizer name for attribution on event pages
    organizerName: String!

    # Contact info - private, only for organizer dashboard and admin
    organizerEmail: String @tag(name: "organizer") @tag(name: "admin")
    organizerPhone: String @tag(name: "organizer") @tag(name: "admin")
    organizerBusinessEmail: String @tag(name: "organizer") @tag(name: "admin")
    organizerBusinessPhone: String @tag(name: "organizer") @tag(name: "admin")
    organizerCompanyName: String @tag(name: "organizer") @tag(name: "admin")
    organizerFirstName: String @tag(name: "organizer") @tag(name: "admin")
    organizerLastName: String @tag(name: "organizer") @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────────
    # STATUS FIELDS - Event lifecycle management
    # Status is public (users see "PUBLISHED"), management fields are restricted
    # ─────────────────────────────────────────────────────────────────────────

    # Event status - public so consumers know if event is live
    status: EventStatus!
    published: Boolean!
    publishedAt: DateTime

    # ─────────────────────────────────────────────────────────────────────────
    # ADMIN-ONLY FIELDS - Approval workflow (platform administrators only)
    # These fields track the approval process and are not shown to organizers
    # until after approval/rejection
    # ─────────────────────────────────────────────────────────────────────────

    submittedForApprovalAt: DateTime @tag(name: "admin")
    approvalDeadline: DateTime @tag(name: "admin")
    approvedAt: DateTime @tag(name: "admin")
    approvedBy: String @tag(name: "admin")
    rejectedAt: DateTime @tag(name: "admin")
    rejectedBy: String @tag(name: "admin")
    rejectionReason: String @tag(name: "organizer") @tag(name: "admin")  # Organizer needs to see why rejected
    isOverdue: Boolean @tag(name: "admin")

    # Capacity and tickets
    totalCapacity: Int!
    availableTickets: Int!
    soldTickets: Int!
    ticketTiers: [TicketTier!]

    # Pricing info (denormalized for filtering)
    minTicketPrice: BigDecimal
    maxTicketPrice: BigDecimal
    currency: String

    # Accessibility metadata
    accessibility: EventAccessibility

    # Media and branding
    bannerImageUrl: String
    thumbnailImageUrl: String
    galleryImages: [String!]
    tags: [String!]
    additionalInfo: JSON

    # Flags
    featured: Boolean!
    isFreeEvent: Boolean!
    soldOut: Boolean! @shareable
    hasWaitlist: Boolean!
    waitlistEnabled: Boolean!
    waitlistCapacity: Int

    # Virtual event support
    isVirtual: Boolean!
    virtualEventUrl: String
    virtualEventPlatform: String

    # Recurring event support
    isRecurring: Boolean!
    recurrencePattern: String
    parentEventId: String

    # Refund/cancellation policies
    refundPolicy: String
    cancellationPolicy: String
    termsAndConditions: String

    # ─────────────────────────────────────────────────────────────────────────
    # AUDIT FIELDS - For tracking changes (internal/admin use)
    # ─────────────────────────────────────────────────────────────────────────

    # Timestamps are useful for organizers to see when event was created/updated
    createdAt: DateTime @tag(name: "organizer") @tag(name: "admin")
    updatedAt: DateTime @tag(name: "organizer") @tag(name: "admin")

    # Actor tracking is internal - used for audit logs
    createdBy: String @tag(name: "internal")
    updatedBy: String @tag(name: "internal")

    # Active flag is needed by organizers to see soft-deleted events
    isActive: Boolean! @tag(name: "organizer") @tag(name: "admin")

    # Version field is for internal optimistic locking only
    version: Int @tag(name: "internal")
}

# ------------------------------
# LOCATION (Simple Address Type)
# ------------------------------
# Location is now a simple address type for events, not a managed entity.
# The platform does not own/manage venues - they are just location info for events.
#
type Location {
    # PUBLIC - for event discovery and maps
    id: ID!
    name: String!
    address: String!
    city: String!
    province: String
    country: String!
    postalCode: String
    coordinates: Coordinates
    description: String
}

type Coordinates {
    latitude: Float
    longitude: Float
}

# ------------------------------
# EVENT ACCESSIBILITY
# ------------------------------
type EventAccessibility {
    wheelchairAccessible: Boolean!
    wheelchairSeatsAvailable: Int
    signLanguageInterpreter: Boolean!
    hearingLoopAvailable: Boolean!
    accessibleParking: Boolean!
    accessibleRestrooms: Boolean!
    assistanceDogsAllowed: Boolean!
    additionalNotes: String
}

# ============================================================================
# SECTION 6: SUPPORTING TYPES
# ============================================================================

# ------------------------------
# TICKET TIER
# ------------------------------
# Ticket tier info is mostly public for ticket selection.
# Inventory details and hidden tiers are restricted to organizers/admins.
#
type TicketTier {
    # PUBLIC - for ticket selection UI
    id: ID!
    eventId: ID!
    organizationId: String @tag(name: "internal") # Multi-tenant tracking
    code: String!
    name: String!
    description: String
    price: BigDecimal!
    originalPrice: BigDecimal
    currency: String!
    maxPerOrder: Int
    minPerOrder: Int
    benefits: [String!]
    salesStartAt: DateTime
    salesEndAt: DateTime
    earlyBirdPrice: BigDecimal
    earlyBirdEndsAt: DateTime

    # PUBLIC - availability info for consumers
    availableQuantity: Int!

    # ORGANIZER/ADMIN - inventory management (full quantity/sold info)
    quantity: Int! @tag(name: "organizer") @tag(name: "admin")
    soldQuantity: Int! @tag(name: "organizer") @tag(name: "admin")
    sortOrder: Int! @tag(name: "organizer") @tag(name: "admin")
    isActive: Boolean! @tag(name: "organizer") @tag(name: "admin")
    isHidden: Boolean! @tag(name: "organizer") @tag(name: "admin")

    # ORGANIZER/ADMIN - access code for hidden/restricted tiers
    accessCode: String @tag(name: "organizer") @tag(name: "admin")

    # AUDIT - internal tracking
    createdAt: DateTime @tag(name: "admin")
    updatedAt: DateTime @tag(name: "admin")
}

# ------------------------------
# EVENT CATEGORY
# ------------------------------
type EventCategory {
    id: ID!
    name: String!
    code: String!
    description: String
    iconUrl: String
    color: String
    sortOrder: Int
    eventCount: Int
    isActive: Boolean!
    createdAt: DateTime
    updatedAt: DateTime
}

# ------------------------------
# PROVINCE
# ------------------------------
type Province {
    id: ID!
    name: String!
    code: String!
    country: String!
    formattedName: String
    cityCount: Int
    createdAt: DateTime
    updatedAt: DateTime
    createdBy: String
    updatedBy: String
    isActive: Boolean!
}

# ------------------------------
# CITY
# ------------------------------
type City {
    id: ID!
    name: String!
    code: String
    provinceId: String
    province: String
    country: String
    eventCount: Int
    createdAt: DateTime
    updatedAt: DateTime
    createdBy: String
    updatedBy: String
    isActive: Boolean!
}

# ------------------------------
# APPROVAL TIMELINE
# ------------------------------
# ─────────────────────────────────────────────────────────────────────────────
# APPROVAL WORKFLOW TYPES (Admin Only)
# ─────────────────────────────────────────────────────────────────────────────
# These types track the event approval process. Only platform administrators
# reviewing and approving events should access this data.

type ApprovalTimeline @tag(name: "admin") {
    eventId: String!
    eventTitle: String!
    organizerId: String!
    organizerName: String!

    # Current state
    currentStatus: EventStatus!
    assignedReviewerId: String
    assignedReviewerName: String

    # Timeline events (audit trail)
    timelineEvents: [TimelineEvent!]!

    # SLA tracking
    submittedAt: DateTime
    slaDeadline: DateTime
    expectedApprovalAt: DateTime
    actualApprovalAt: DateTime
    totalProcessingTimeHours: Int
    isOverdue: Boolean!
    hoursUntilDeadline: Int
    slaCompliancePercentage: Float

    # Escalation tracking
    escalation: ApprovalEscalation
    hasActiveEscalation: Boolean!

    # Iteration tracking (for changes requested flow)
    submissionCount: Int!
    currentIteration: Int!

    # Quick stats
    totalComments: Int!
    lastActivityAt: DateTime
}

type TimelineEvent @tag(name: "admin") {
    id: ID!
    eventId: String!
    timestamp: DateTime!
    action: ApprovalAction!

    # Actor information
    actorId: String!
    actorName: String!
    actorRole: String

    # Status at this point
    previousStatus: EventStatus
    newStatus: EventStatus

    # Details
    description: String!
    comments: String
    internalNotes: String @tag(name: "internal")

    # For escalations
    isEscalationRelated: Boolean!

    # Metadata for extensibility
    metadata: JSON
}

# ─────────────────────────────────────────────────────────────────────────────
# PLATFORM CONFIGURATION (Admin Only)
# ─────────────────────────────────────────────────────────────────────────────
# Configuration is stored in database for runtime flexibility.
# Admin can update these settings without deployment.

type PlatformConfiguration @tag(name: "admin") {
    id: ID!

    # APPROVAL SLA SETTINGS
    approvalSlaHours: Int!                        # Default: 72 hours (3 days)
    approvalWarningThresholdHours: Int!           # Warning at X hours before deadline

    # AUTO-ESCALATION SETTINGS
    autoEscalationEnabled: Boolean!
    escalationDelayHours: Int!                    # Hours after SLA breach to escalate
    escalationRecipientRole: String!              # Role to escalate to (e.g., "SENIOR_ADMIN")
    escalationReminderIntervalHours: Int!         # Reminder interval after escalation
    maxEscalationReminders: Int!                  # Max reminders before marking critical

    # NOTIFICATION SETTINGS
    organizerNotificationChannel: ApprovalNotificationChannel!
    adminNotificationChannel: ApprovalNotificationChannel!
    sendSlaWarningNotifications: Boolean!
    sendEscalationNotifications: Boolean!

    # WORKFLOW SETTINGS
    requireCommentsOnRejection: Boolean!
    requireCommentsOnChangesRequested: Boolean!
    allowSelfApproval: Boolean!                   # Can organizer approve own events?

    # Audit fields
    updatedAt: DateTime!
    updatedBy: String!
}

input UpdatePlatformConfigurationInput {
    approvalSlaHours: Int
    approvalWarningThresholdHours: Int
    autoEscalationEnabled: Boolean
    escalationDelayHours: Int
    escalationRecipientRole: String
    escalationReminderIntervalHours: Int
    maxEscalationReminders: Int
    organizerNotificationChannel: ApprovalNotificationChannel
    adminNotificationChannel: ApprovalNotificationChannel
    sendSlaWarningNotifications: Boolean
    sendEscalationNotifications: Boolean
    requireCommentsOnRejection: Boolean
    requireCommentsOnChangesRequested: Boolean
    allowSelfApproval: Boolean
}

type PlatformConfigurationMutationResponse @tag(name: "admin") {
    success: Boolean!
    message: String
    data: PlatformConfiguration
    errors: [String!]!
}

# ─────────────────────────────────────────────────────────────────────────────
# APPROVAL ESCALATION (Admin Only)
# ─────────────────────────────────────────────────────────────────────────────

type ApprovalEscalation @tag(name: "admin") {
    id: ID!
    eventId: String!
    eventTitle: String!

    # Escalation details
    status: EscalationStatus!
    reason: String!                               # e.g., "SLA breach - 24 hours overdue"

    # Timing
    triggeredAt: DateTime!
    acknowledgedAt: DateTime
    resolvedAt: DateTime

    # Actors
    escalatedTo: String!                          # User ID of senior admin
    escalatedToName: String!
    acknowledgedBy: String
    acknowledgedByName: String
    resolvedBy: String
    resolvedByName: String
    resolutionNotes: String

    # Original assignment
    originalReviewerId: String
    originalReviewerName: String

    # Reminder tracking
    remindersSent: Int!
    lastReminderAt: DateTime
    nextReminderAt: DateTime

    # SLA context
    hoursOverdue: Int!
    slaDeadline: DateTime!
}

# ─────────────────────────────────────────────────────────────────────────────
# APPROVAL NOTIFICATION (Admin Only)
# ─────────────────────────────────────────────────────────────────────────────

type ApprovalNotification @tag(name: "admin") {
    id: ID!
    eventId: String!
    eventTitle: String!

    # Notification details
    type: ApprovalNotificationType!
    channel: ApprovalNotificationChannel!
    recipientId: String!
    recipientEmail: String
    recipientName: String!

    # Content
    subject: String!
    message: String!
    actionUrl: String                             # Deep link to event/approval page

    # Status
    sentAt: DateTime
    deliveredAt: DateTime
    readAt: DateTime
    failedAt: DateTime
    failureReason: String

    # Retry tracking
    retryCount: Int!
    nextRetryAt: DateTime
}

# ─────────────────────────────────────────────────────────────────────────────
# APPROVAL STATISTICS (Admin Only)
# ─────────────────────────────────────────────────────────────────────────────

type ApprovalStats @tag(name: "admin") {
    # Volume metrics
    totalPendingReviews: Int!
    totalOverdue: Int!
    totalEscalated: Int!

    # Today's metrics
    submittedToday: Int!
    approvedToday: Int!
    rejectedToday: Int!
    changesRequestedToday: Int!

    # SLA metrics
    averageProcessingTimeHours: Float!
    slaComplianceRate: Float!                     # Percentage approved within SLA

    # Breakdown by status
    pendingByDaysWaiting: [DaysWaitingBreakdown!]!

    # Escalation metrics
    activeEscalations: Int!
    escalationsThisWeek: Int!
    averageEscalationResolutionHours: Float
}

type DaysWaitingBreakdown @tag(name: "admin") {
    daysWaiting: Int!                             # 0, 1, 2, 3+
    count: Int!
    percentage: Float!
}

# ─────────────────────────────────────────────────────────────────────────────
# APPROVAL WORKFLOW PAGINATION TYPES (Admin Only)
# ─────────────────────────────────────────────────────────────────────────────

# Cursor pagination for approval timelines
type ApprovalTimelineConnection @tag(name: "admin") {
    edges: [ApprovalTimelineEdge!]!
    pageInfo: PageInfo!
    totalCount: Int!
}

type ApprovalTimelineEdge @tag(name: "admin") {
    node: ApprovalTimeline!
    cursor: String!
}

# Offset pagination for approval timelines
type ApprovalTimelineOffsetPage @tag(name: "admin") {
    content: [ApprovalTimeline!]!
    pageNumber: Int!
    pageSize: Int!
    totalElements: Int!
    totalPages: Int!
    hasNext: Boolean!
    hasPrevious: Boolean!
}

# Cursor pagination for escalations
type ApprovalEscalationConnection @tag(name: "admin") {
    edges: [ApprovalEscalationEdge!]!
    pageInfo: PageInfo!
    totalCount: Int!
}

type ApprovalEscalationEdge @tag(name: "admin") {
    node: ApprovalEscalation!
    cursor: String!
}

# Offset pagination for escalations
type ApprovalEscalationOffsetPage @tag(name: "admin") {
    content: [ApprovalEscalation!]!
    pageNumber: Int!
    pageSize: Int!
    totalElements: Int!
    totalPages: Int!
    hasNext: Boolean!
    hasPrevious: Boolean!
}

# ─────────────────────────────────────────────────────────────────────────────
# APPROVAL WORKFLOW INPUT TYPES
# ─────────────────────────────────────────────────────────────────────────────

input ApprovalTimelineFilterInput {
    status: EventStatus
    isOverdue: Boolean
    hasActiveEscalation: Boolean
    assignedReviewerId: String
    submittedAfter: DateTime
    submittedBefore: DateTime
    organizerId: String
    searchQuery: String                           # Search by event title
}

input AssignReviewerInput {
    eventId: ID!
    reviewerId: String!
    reviewerName: String!
    internalNotes: String
}

input ResolveEscalationInput {
    escalationId: ID!
    resolutionNotes: String!
    action: ApprovalAction!                       # APPROVED, REJECTED, CHANGES_REQUESTED
}

# ─────────────────────────────────────────────────────────────────────────────
# APPROVAL WORKFLOW MUTATION RESPONSES
# ─────────────────────────────────────────────────────────────────────────────

type ApprovalTimelineMutationResponse @tag(name: "admin") {
    success: Boolean!
    message: String
    data: ApprovalTimeline
    errors: [String!]!
}

type ApprovalEscalationMutationResponse @tag(name: "admin") {
    success: Boolean!
    message: String
    data: ApprovalEscalation
    errors: [String!]!
}

# ------------------------------
# EVENT LIFECYCLE
# ------------------------------
# Event lifecycle tracking is useful for organizers managing their events
# and admins monitoring the platform. Not needed by mobile consumers.

type EventLifecycle @tag(name: "organizer") @tag(name: "admin") {
    eventId: String!
    currentStatus: EventStatus!
    createdAt: DateTime
    lastStatusChange: DateTime
    createdBy: String @tag(name: "internal")  # Internal audit
    statusTransitions: [StatusTransition!]
    allowedTransitions: [EventStatus!]
}

type StatusTransition @tag(name: "organizer") @tag(name: "admin") {
    fromStatus: EventStatus
    toStatus: EventStatus!
    transitionedAt: DateTime!
    transitionedBy: String @tag(name: "internal")  # Internal audit
    reason: String
    metadata: JSON @tag(name: "internal")  # Internal debugging
}

# ============================================================================
# SECTION 8: STATISTICS TYPES
# ============================================================================
#
# Statistics types are used for dashboards and analytics. Platform-wide stats
# are admin-only, while per-event stats are available to organizers for their
# own events.
#

# ─────────────────────────────────────────────────────────────────────────────
# PLATFORM-WIDE STATISTICS (Admin Dashboard Only)
# ─────────────────────────────────────────────────────────────────────────────
# These aggregate stats across all events on the platform.
# Only platform administrators should see this data.

type EventStats @tag(name: "admin") {
    totalEvents: Int!
    publishedEvents: Int!
    approvedNotPublishedEvents: Int!
    draftEvents: Int!
    pendingApprovalEvents: Int!
    cancelledEvents: Int!
    completedEvents: Int!
    rejectedEvents: Int!
    totalCapacity: Int!
    totalSoldTickets: Int!
    totalRevenue: BigDecimal
    eventsByCategory: [EventCategoryStats!]
    eventsByStatus: [EventStatusStats!]
    eventsByOrganizer: [EventOrganizerStats!]
    recentEvents: [Event!]
}

type EventCategoryStats @tag(name: "admin") {
    categoryId: String!
    category: String!
    count: Int!
    percentage: Float!
    totalCapacity: Int!
    totalSoldTickets: Int!
    totalRevenue: BigDecimal
}

type EventStatusStats @tag(name: "admin") {
    status: EventStatus!
    count: Int!
    percentage: Float!
}

type EventOrganizerStats @tag(name: "admin") {
    organizerId: String!
    organizerName: String!
    eventCount: Int!
    totalCapacity: Int!
    totalSoldTickets: Int!
    totalRevenue: BigDecimal
}

# ─────────────────────────────────────────────────────────────────────────────
# PER-EVENT STATISTICS (Organizer Dashboard + Admin)
# ─────────────────────────────────────────────────────────────────────────────
# These stats are for a specific event. Organizers can see stats for their
# own events, admins can see stats for any event.

type EventTicketStatistics @tag(name: "organizer") @tag(name: "admin") {
    eventId: ID!
    eventTitle: String!
    eventDate: DateTime!
    totalTicketsAvailable: Int!
    totalTicketsSold: Int!
    totalTicketsRefunded: Int!
    totalCommissionEarned: BigDecimal
    totalGrossRevenue: BigDecimal
    tierStatistics: [TicketTierStats!]
    overallSalesPercentage: Float!
    bestSellingTier: String
}

type TicketTierStats @tag(name: "organizer") @tag(name: "admin") {
    eventId: ID!
    tierId: ID!
    tierCode: String!
    tierName: String!
    price: BigDecimal!
    totalQuantity: Int!
    isActive: Boolean!
    ticketsSold: Int!
    ticketsRefunded: Int!
    grossRevenue: BigDecimal
    salesPercentage: Float!
}

# City statistics for event analytics (admin only)
type CityStats @tag(name: "admin") {
    cityId: String
    cityName: String!
    country: String!
    eventCount: Int!
}

# ─────────────────────────────────────────────────────────────────────────────
# EXPORT TYPES (Admin Only)
# ─────────────────────────────────────────────────────────────────────────────
# Report exports are only available to platform administrators.
# Shared across services via federation.

type ReportExport @shareable @tag(name: "admin") {
    success: Boolean! @shareable
    downloadUrl: String @shareable
    expiresAt: DateTime @shareable
    format: ExportFormat! @shareable
    generatedAt: DateTime! @shareable
    fileName: String @shareable
    errorMessage: String @shareable
}

# ============================================================================
# SECTION 9: PAGINATION TYPES
# ============================================================================

# Cursor-based pagination (Relay spec) for infinite scroll
input CursorPaginationInput {
    first: Int
    after: String
    last: Int
    before: String
}

# Shared type for cursor-based pagination - must have @shareable for federation
type PageInfo @shareable {
    hasNextPage: Boolean @shareable
    hasPreviousPage: Boolean @shareable
    startCursor: String @shareable
    endCursor: String @shareable
    totalCount: Int @shareable
    totalElements: Int @shareable
    totalPages: Int @shareable
    currentPage: Int @shareable
    pageSize: Int @shareable
    hasNext: Boolean @shareable
    hasPrevious: Boolean @shareable
}

type EventConnection {
    edges: [EventEdge!]!
    pageInfo: PageInfo!
}

type EventEdge {
    node: Event!
    cursor: String!
}

type LocationConnection {
    edges: [LocationEdge!]!
    pageInfo: PageInfo!
}

type LocationEdge {
    node: Location!
    cursor: String!
}

type CityConnection {
    edges: [CityEdge!]!
    pageInfo: PageInfo!
}

type CityEdge {
    node: City!
    cursor: String!
}

type ProvinceConnection {
    edges: [ProvinceEdge!]!
    pageInfo: PageInfo!
}

type ProvinceEdge {
    node: Province!
    cursor: String!
}

type EventCategoryConnection {
    edges: [EventCategoryEdge!]!
    pageInfo: PageInfo!
}

type EventCategoryEdge {
    node: EventCategory!
    cursor: String!
}

# NOTE: ApprovalTimelineConnection and ApprovalTimelineEdge are defined above with @tag(name: "admin")

# Offset-based pagination (Spring Data) for admin/dashboard tables
input OffsetPaginationInput {
    page: Int = 0
    size: Int = 20
    sortBy: String = "createdAt"
    sortDirection: SortDirection = DESC
}

# Shared type - must have @shareable on all fields for federation
type PaginationInfo @shareable {
    pageNumber: Int @shareable
    pageSize: Int! @shareable
    totalElements: Int @shareable
    totalPages: Int! @shareable
    totalCount: Int @shareable
    currentPage: Int @shareable
    hasNext: Boolean @shareable
    hasPrevious: Boolean @shareable
    hasNextPage: Boolean @shareable
    hasPreviousPage: Boolean @shareable
}

type EventOffsetPage {
    content: [Event!]!
    pageNumber: Int!
    pageSize: Int!
    totalElements: Int!
    totalPages: Int!
    hasNext: Boolean!
    hasPrevious: Boolean!
}


type CityOffsetPage {
    content: [City!]!
    pageNumber: Int!
    pageSize: Int!
    totalElements: Int!
    totalPages: Int!
    hasNext: Boolean!
    hasPrevious: Boolean!
}

type ProvinceOffsetPage {
    content: [Province!]!
    pageNumber: Int!
    pageSize: Int!
    totalElements: Int!
    totalPages: Int!
    hasNext: Boolean!
    hasPrevious: Boolean!
}

type EventCategoryOffsetPage {
    content: [EventCategory!]!
    pageNumber: Int!
    pageSize: Int!
    totalElements: Int!
    totalPages: Int!
    hasNext: Boolean!
    hasPrevious: Boolean!
}

# NOTE: ApprovalTimelineOffsetPage is defined above with @tag(name: "admin")

