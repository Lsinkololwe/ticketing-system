    categoryIds: [String!]
    cityId: String
    cityName: String
    country: String
    provinceId: String
    startDate: DateTime
    endDate: DateTime
    minPrice: BigDecimal
    maxPrice: BigDecimal
    isFreeEvent: Boolean
    hasAvailableTickets: Boolean
    isAccessible: Boolean
    isVirtual: Boolean
    isFeatured: Boolean
    tags: [String!]
