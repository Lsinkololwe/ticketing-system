# ============================================================================
# SECTION 15: ROOT QUERY TYPE
# Tags indicate which clients should include these queries in their operations
# ============================================================================
type Query {
    # ========================================================================
    # TICKET QUERIES
    # PUBLIC - Single ticket lookup (owner can view their own ticket)
    # ORGANIZER/ADMIN - Paginated lists for management
    # ========================================================================

    # PUBLIC - Ticket lookup for ticket holders
    ticket(id: ID!): Ticket
    ticketByNumber(ticketNumber: String!): Ticket

    # ORGANIZER/ADMIN - Offset pagination for dashboard tables
    ticketsByEventOffsetPagination(eventId: String!, pagination: OffsetPaginationInput): TicketOffsetPage! @tag(name: "organizer") @tag(name: "admin")
    ticketsByBuyerOffsetPagination(buyerId: String!, status: TicketStatus, pagination: OffsetPaginationInput): TicketOffsetPage! @tag(name: "admin")
    ticketsByOrganizerOffsetPagination(organizerId: String!, filter: TicketFilterInput, pagination: OffsetPaginationInput): TicketOffsetPage! @tag(name: "organizer") @tag(name: "admin")
    searchTicketsOffsetPagination(filter: TicketFilterInput!, pagination: OffsetPaginationInput): TicketOffsetPage! @tag(name: "admin")

    # ORGANIZER/ADMIN - Cursor pagination for dashboard lists
    ticketsByEventCursorPagination(eventId: String!, pagination: CursorPaginationInput): TicketConnection! @tag(name: "organizer") @tag(name: "admin")
    # MOBILE - Customer views their own tickets
    ticketsByBuyerCursorPagination(buyerId: String!, status: TicketStatus, pagination: CursorPaginationInput): TicketConnection! @tag(name: "mobile")
    ticketsByOrganizerCursorPagination(organizerId: String!, filter: TicketFilterInput, pagination: CursorPaginationInput): TicketConnection! @tag(name: "organizer") @tag(name: "admin")
    searchTicketsCursorPagination(filter: TicketFilterInput!, pagination: CursorPaginationInput): TicketConnection! @tag(name: "admin")

    # ORGANIZER/ADMIN - Ticket counts for dashboard stats
    ticketCountByEvent(eventId: String!): Int! @tag(name: "organizer") @tag(name: "admin")
    ticketCountByBuyer(buyerId: String!): Int! @tag(name: "mobile")

    # ========================================================================
    # FINANCIAL TRANSACTION QUERIES - REMOVED
    # Replaced by:
    # - PaymentAttempt queries for payment lifecycle tracking
    # - JournalEntry queries for accounting records
    # ========================================================================

    # ========================================================================
    # PAYMENT ATTEMPT QUERIES
    # ADMIN-ONLY - Payment attempt lifecycle tracking
    # Tracks the operational journey of payments through PawaPay
    # ========================================================================

    # ADMIN - Single payment attempt lookup
    paymentAttempt(id: ID!): PaymentAttempt @tag(name: "admin")
    paymentAttemptByDepositId(depositId: String!): PaymentAttempt @tag(name: "admin")
    paymentAttemptByAttemptNumber(attemptNumber: String!): PaymentAttempt @tag(name: "admin")

    # ADMIN - Payment attempts by ticket (all attempts for a purchase)
    paymentAttemptsByTicket(ticketId: String!): [PaymentAttempt!]! @tag(name: "admin")
    latestPaymentAttemptByTicket(ticketId: String!): PaymentAttempt @tag(name: "admin")
    successfulPaymentAttemptByTicket(ticketId: String!): PaymentAttempt @tag(name: "admin")

    # ADMIN - Payment attempts by status (for monitoring/recovery)
    paymentAttemptsByStatus(status: PaymentAttemptStatus!): [PaymentAttempt!]! @tag(name: "admin")
    pendingPaymentAttempts: [PaymentAttempt!]! @tag(name: "admin")
    confirmedUnfulfilledPaymentAttempts: [PaymentAttempt!]! @tag(name: "admin")

    # ADMIN - Payment attempts by event/buyer
    paymentAttemptsByEvent(eventId: String!): [PaymentAttempt!]! @tag(name: "admin")
    paymentAttemptsByBuyer(buyerId: String!): [PaymentAttempt!]! @tag(name: "admin")

    # ADMIN - Statistics
    paymentAttemptCountByStatus(status: PaymentAttemptStatus!): Int! @tag(name: "admin")
    hasSuccessfulPayment(ticketId: String!): Boolean! @tag(name: "admin")

    # ========================================================================
    # ESCROW ACCOUNT QUERIES
    # ADMIN-ONLY - Escrow account management is platform-level
    # ========================================================================

    # ADMIN - Single escrow account lookup
    escrowAccount(id: ID!): EventEscrowAccount @tag(name: "admin")
    escrowAccountByNumber(accountNumber: String!): EventEscrowAccount @tag(name: "admin")
    escrowAccountByEvent(eventId: String!): EventEscrowAccount @tag(name: "admin")

    # ADMIN - Offset pagination for escrow dashboard tables
    escrowAccountsOffsetPagination(filter: EscrowAccountFilterInput, pagination: OffsetPaginationInput): EscrowAccountOffsetPage! @tag(name: "admin")
    escrowAccountsByOrganizerOffsetPagination(organizerId: String!, pagination: OffsetPaginationInput): EscrowAccountOffsetPage! @tag(name: "admin")

    # ADMIN - Cursor pagination for escrow lists
    escrowAccountsCursorPagination(filter: EscrowAccountFilterInput, pagination: CursorPaginationInput): EscrowAccountConnection! @tag(name: "admin")
    escrowAccountsByOrganizerCursorPagination(organizerId: String!, pagination: CursorPaginationInput): EscrowAccountConnection! @tag(name: "admin")

    # ADMIN - Escrow balance and summary
    escrowAccountBalance(accountId: String!): BigDecimal @tag(name: "admin")
    accountSummary(accountId: String!): AccountSummary @tag(name: "admin")
    platformSummary: PlatformSummary! @tag(name: "admin")

    # ========================================================================
    # REFUND REQUEST QUERIES
    # ORGANIZER - See refunds for own events
    # ADMIN - See all refunds platform-wide
    # ========================================================================

    # ORGANIZER/ADMIN - Single refund lookup
    refundRequest(id: ID!): RefundRequest @tag(name: "organizer") @tag(name: "admin")
    refundRequestByRequestId(requestId: String!): RefundRequest @tag(name: "organizer") @tag(name: "admin")
    refundRequestsByTicket(ticketId: String!): [RefundRequest!]! @tag(name: "organizer") @tag(name: "admin")

    # ADMIN - Offset pagination for refund dashboard tables
    refundRequestsOffsetPagination(filter: RefundRequestFilterInput!, pagination: OffsetPaginationInput): RefundRequestOffsetPage! @tag(name: "admin")
    refundRequestsByBuyerOffsetPagination(buyerId: String!, pagination: OffsetPaginationInput): RefundRequestOffsetPage! @tag(name: "admin")
    # ORGANIZER/ADMIN - Refunds by event
    refundRequestsByEventOffsetPagination(eventId: String!, pagination: OffsetPaginationInput): RefundRequestOffsetPage! @tag(name: "organizer") @tag(name: "admin")
    pendingRefundRequestsOffsetPagination(pagination: OffsetPaginationInput): RefundRequestOffsetPage! @tag(name: "admin")

    # ADMIN - Cursor pagination for refund lists
    refundRequestsCursorPagination(filter: RefundRequestFilterInput!, pagination: CursorPaginationInput): RefundRequestConnection! @tag(name: "admin")
    refundRequestsByBuyerCursorPagination(buyerId: String!, pagination: CursorPaginationInput): RefundRequestConnection! @tag(name: "admin")
    refundRequestsByEventCursorPagination(eventId: String!, pagination: CursorPaginationInput): RefundRequestConnection! @tag(name: "organizer") @tag(name: "admin")
    pendingRefundRequestsCursorPagination(pagination: CursorPaginationInput): RefundRequestConnection! @tag(name: "admin")

    # MOBILE - Refund eligibility and calculation for customer
    isTicketEligibleForRefund(ticketId: String!): Boolean! @tag(name: "mobile")
    calculateRefundAmount(ticketId: String!): RefundCalculation! @tag(name: "mobile")
    # ORGANIZER/ADMIN - Refund summary for event
    eventRefundSummary(eventId: String!): RefundSummary @tag(name: "organizer") @tag(name: "admin")

    # ========================================================================
    # PAYOUT REQUEST QUERIES
    # ORGANIZER - Track own payout requests
    # ADMIN - Manage all payout requests
    # ========================================================================

    # ORGANIZER/ADMIN - Single payout lookup
    payoutRequest(id: ID!): PayoutRequest @tag(name: "organizer") @tag(name: "admin")
    payoutRequestByRequestId(requestId: String!): PayoutRequest @tag(name: "organizer") @tag(name: "admin")

    # ADMIN - Offset pagination for all payouts
    payoutRequestsOffsetPagination(filter: PayoutRequestFilterInput!, pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")
    # ORGANIZER/ADMIN - Payouts by organizer
    payoutRequestsByOrganizerOffsetPagination(organizerId: String!, pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "organizer") @tag(name: "admin")
    payoutRequestsByEventOffsetPagination(eventId: String!, pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "organizer") @tag(name: "admin")
    # ADMIN - Pending and failed payouts queue
    pendingPayoutRequestsOffsetPagination(pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")
    failedPayoutRequestsOffsetPagination(pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")

    # ADMIN - Cursor pagination for payout lists
    payoutRequestsCursorPagination(filter: PayoutRequestFilterInput!, pagination: CursorPaginationInput): PayoutRequestConnection! @tag(name: "admin")
    # ORGANIZER - Own payout request history
    payoutRequestsByOrganizerCursorPagination(organizerId: String!, pagination: CursorPaginationInput): PayoutRequestConnection! @tag(name: "organizer") @tag(name: "admin")
    payoutRequestsByEventCursorPagination(eventId: String!, pagination: CursorPaginationInput): PayoutRequestConnection! @tag(name: "organizer") @tag(name: "admin")
    pendingPayoutRequestsCursorPagination(pagination: CursorPaginationInput): PayoutRequestConnection! @tag(name: "admin")
    failedPayoutRequestsCursorPagination(pagination: CursorPaginationInput): PayoutRequestConnection! @tag(name: "admin")

    # ADMIN - Payout Recovery Queries
    payoutRequestsForReviewOffsetPagination(reviewStatus: PayoutReviewStatus, pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")
    payoutRequestsForReviewCursorPagination(reviewStatus: PayoutReviewStatus, pagination: CursorPaginationInput): PayoutRequestConnection! @tag(name: "admin")
    stuckPayoutRequestsOffsetPagination(pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")
    stuckPayoutRequestsCursorPagination(pagination: CursorPaginationInput): PayoutRequestConnection! @tag(name: "admin")
    retryablePayoutRequestsOffsetPagination(pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")
    recentlyResolvedPayoutRequestsOffsetPagination(pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")
    payoutRequestsByIssueTypeOffsetPagination(issueType: PayoutIssueType!, pagination: OffsetPaginationInput): PayoutRequestOffsetPage! @tag(name: "admin")
    payoutRecoverySummary: PayoutRecoverySummary! @tag(name: "admin")

    # ========================================================================
    # BANK ACCOUNT QUERIES
    # ORGANIZER - Manage own bank accounts
    # ADMIN - View and verify all bank accounts
    # ========================================================================

    # ORGANIZER/ADMIN - Bank account lookups
    bankAccount(id: ID!): BankAccount @tag(name: "organizer") @tag(name: "admin")
    bankAccountsByOrganizer(organizerId: String!): [BankAccount!]! @tag(name: "organizer") @tag(name: "admin")
    defaultBankAccount(organizerId: String!): BankAccount @tag(name: "organizer") @tag(name: "admin")

    # ========================================================================
    # STATISTICS QUERIES
    # ADMIN - Platform-wide statistics
    # ========================================================================

    # ADMIN - Ticket statistics (platform-wide)
    ticketStats(eventId: ID): TicketStats! @tag(name: "admin")
    # ADMIN - Transaction statistics
    transactionStats(eventId: ID, organizerId: ID): TransactionStats! @tag(name: "admin")
    # ADMIN - Payout request statistics
    payoutRequestStats(organizerId: ID): PayoutRequestStats! @tag(name: "admin")

    # ========================================================================
    # FINANCIAL REPORTING QUERIES
    # ADMIN - Platform financial reporting
    # ========================================================================

    # ADMIN - Financial reports and exports
    financialReport(filter: FinancialReportFilterInput!): FinancialReport! @tag(name: "admin")
    exportFinancialReport(filter: FinancialReportFilterInput!, format: ExportFormat!): ReportExport! @tag(name: "admin")
    # ORGANIZER/ADMIN - Event sales report
    exportSalesReport(eventId: ID!, format: ExportFormat!): ReportExport! @tag(name: "organizer") @tag(name: "admin")

    # ========================================================================
    # RESERVATION QUERIES
    # MOBILE - Customer checkout flow
    # ========================================================================

    # MOBILE - Reservation lookup during checkout
    reservation(id: ID!): TicketReservation @tag(name: "mobile")
    myActiveReservations(userId: ID!): [TicketReservation!]! @tag(name: "mobile")

    # ADMIN - Reservation monitoring for event management
    reservationsByEventOffsetPagination(eventId: ID!, pagination: OffsetPaginationInput): ReservationOffsetPage! @tag(name: "admin")
    expiredReservationsOffsetPagination(eventId: ID, since: DateTime!, pagination: OffsetPaginationInput): ReservationOffsetPage! @tag(name: "admin")

    # ADMIN - Cursor pagination for reservation lists
    reservationsByEventCursorPagination(eventId: ID!, pagination: CursorPaginationInput): ReservationConnection! @tag(name: "admin")
    expiredReservationsCursorPagination(eventId: ID, since: DateTime!, pagination: CursorPaginationInput): ReservationConnection! @tag(name: "admin")

    # ========================================================================
    # PROMO CODE QUERIES
    # ORGANIZER - Promo code management
    # MOBILE - Promo code validation during checkout
    # ========================================================================

    # ORGANIZER/ADMIN - Promo code lookups
    promoCode(id: ID!): PromoCode @tag(name: "organizer") @tag(name: "admin")
    promoCodeByCode(code: String!): PromoCode @tag(name: "organizer") @tag(name: "admin")
    # MOBILE - Validate promo code during checkout
    validatePromoCode(code: String!, eventId: ID!, amount: BigDecimal): PromoCodeValidation! @tag(name: "mobile")
    # ORGANIZER - Promo code management
    eventPromoCodes(eventId: ID!): [PromoCode!]! @tag(name: "organizer") @tag(name: "admin")
    organizerPromoCodes(organizerId: ID!): [PromoCode!]! @tag(name: "organizer") @tag(name: "admin")

    # ========================================================================
    # LIVE DASHBOARD QUERIES
    # ORGANIZER - Real-time event day dashboard
    # ========================================================================

    # ORGANIZER - Live check-in dashboard for event day
    eventLiveDashboard(eventId: ID!): LiveDashboard! @tag(name: "organizer")

    # ========================================================================
    # FINANCIAL ENGINE QUERIES - Double-Entry Bookkeeping
    # ADMIN-ONLY - Core accounting infrastructure
    # ========================================================================

    # ADMIN - Chart of Accounts queries
    chartOfAccounts: [ChartOfAccountsEntry!]! @tag(name: "admin")
    chartOfAccountsEntry(id: ID!): ChartOfAccountsEntry @tag(name: "admin")
    chartOfAccountsByCode(accountCode: String!): ChartOfAccountsEntry @tag(name: "admin")
    chartOfAccountsByType(accountType: AccountType!): [ChartOfAccountsEntry!]! @tag(name: "admin")
    chartOfAccountsOffsetPagination(pagination: OffsetPaginationInput): ChartOfAccountsOffsetPage! @tag(name: "admin")

    # ADMIN - Journal Entry queries
    journalEntry(id: ID!): JournalEntry @tag(name: "admin")
    journalEntryByNumber(entryNumber: String!): JournalEntry @tag(name: "admin")
    journalEntriesByCorrelationId(correlationId: String!): [JournalEntry!]! @tag(name: "admin")
    journalEntriesOffsetPagination(filter: JournalEntryFilterInput, pagination: OffsetPaginationInput): JournalEntryOffsetPage! @tag(name: "admin")
    journalEntriesByAccountCode(accountCode: String!, pagination: OffsetPaginationInput): JournalEntryOffsetPage! @tag(name: "admin")
    pendingJournalEntriesOffsetPagination(pagination: OffsetPaginationInput): JournalEntryOffsetPage! @tag(name: "admin")

    # ADMIN - Trial Balance and Account Balance queries
    trialBalance(asOf: DateTime): [AccountBalance!]! @tag(name: "admin")
    accountBalance(accountCode: String!, asOf: DateTime): AccountBalance @tag(name: "admin")

    # ADMIN - Platform Account queries
    platformAccounts: [PlatformAccount!]! @tag(name: "admin")
    platformAccount(id: ID!): PlatformAccount @tag(name: "admin")
    platformAccountByType(accountType: PlatformAccountType!): PlatformAccount @tag(name: "admin")

    # ADMIN - Standalone Escrow Transaction queries
    escrowTransaction(id: ID!): StandaloneEscrowTransaction @tag(name: "admin")
    escrowTransactionsByAccount(escrowAccountId: String!, pagination: OffsetPaginationInput): EscrowTransactionOffsetPage! @tag(name: "admin")
    escrowTransactionsByTicket(ticketId: String!): [StandaloneEscrowTransaction!]! @tag(name: "admin")
    escrowTransactionsUnlinked: [StandaloneEscrowTransaction!]! @tag(name: "admin")
    escrowBalance(escrowAccountId: String!): BigDecimal! @tag(name: "admin")
    escrowBalanceAsOf(escrowAccountId: String!, asOf: DateTime!): BigDecimal! @tag(name: "admin")

    # ========================================================================
    # CHARGEBACK QUERIES
    # ADMIN-ONLY - Chargeback management
    # ========================================================================

    # ADMIN - Chargeback queries
    chargeback(id: ID!): ChargebackRecord @tag(name: "admin")
    chargebackByChargebackId(chargebackId: String!): ChargebackRecord @tag(name: "admin")
    chargebacksOffsetPagination(filter: ChargebackFilterInput, pagination: OffsetPaginationInput): ChargebackOffsetPage! @tag(name: "admin")
    chargebacksByOrganizer(organizerId: String!, pagination: OffsetPaginationInput): ChargebackOffsetPage! @tag(name: "admin")
    chargebacksByEvent(eventId: String!, pagination: OffsetPaginationInput): ChargebackOffsetPage! @tag(name: "admin")
    pendingChargebacks: [ChargebackRecord!]! @tag(name: "admin")
    chargebacksPendingRecovery: [ChargebackRecord!]! @tag(name: "admin")
    chargebackStats(organizerId: String, eventId: String): ChargebackStats! @tag(name: "admin")

    # ========================================================================
    # RECONCILIATION QUERIES
    # ADMIN-ONLY - Reconciliation engine
    # ========================================================================

    # ADMIN - Reconciliation queries
    reconciliationRun(id: ID!): ReconciliationRun @tag(name: "admin")
    reconciliationRunsOffsetPagination(filter: ReconciliationFilterInput, pagination: OffsetPaginationInput): ReconciliationRunOffsetPage! @tag(name: "admin")
    reconciliationRunsByType(type: ReconciliationType!, pagination: OffsetPaginationInput): ReconciliationRunOffsetPage! @tag(name: "admin")
    reconciliationRunsRequiringReview: [ReconciliationRun!]! @tag(name: "admin")
    reconciliationSummary(type: ReconciliationType, startDate: DateTime, endDate: DateTime): ReconciliationSummary! @tag(name: "admin")

    # ========================================================================
    # ESCROW-JOURNAL CROSS-VERIFICATION QUERIES
    # ADMIN-ONLY - Verify escrow balances match journal entries
    # ========================================================================

    # ADMIN - Verify single event's escrow-journal consistency
    escrowJournalVerification(eventId: ID!): EscrowJournalVerificationResponse! @tag(name: "admin")

    # ADMIN - Verify all escrow accounts against journal entries
    escrowJournalVerificationAll: [EscrowJournalVerificationResponse!]! @tag(name: "admin")

    # ADMIN - Get only inconsistencies (filtered view)
    escrowJournalInconsistencies: [EscrowJournalVerificationResponse!]! @tag(name: "admin")

}

# ============================================================================
# SECTION 16: ROOT MUTATION TYPE
# Tags indicate which clients should include these mutations in their operations
# ============================================================================
type Mutation {
    # ========================================================================
    # TICKET MUTATIONS
    # MOBILE - Purchase flow, ORGANIZER - Validation
    # ========================================================================

    # MOBILE - Customer ticket purchase
    # NOTE: buyerId extracted from JWT authentication - not passed as parameter (OWASP A01:2021)
    purchaseTicket(input: TicketPurchaseInput!): PurchaseTicketMutationResponse! @auth(requires: CUSTOMER) @tag(name: "mobile")
    # ORGANIZER - Ticket validation at venue (scanner app)
    validateTicket(ticketNumber: String!): ValidateTicketMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    useTicket(ticketNumber: String!): UseTicketMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer")
    # ORGANIZER/ADMIN - Cancel and refund tickets
    # NOTE: processedBy extracted from JWT authentication (OWASP A01:2021 compliance)
    cancelTicket(ticketNumber: String!, reason: String!): CancelTicketMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")
    refundTicket(ticketNumber: String!, reason: String!): RefundTicketMutationResponse! @auth(requires: ORGANIZER) @tag(name: "organizer") @tag(name: "admin")

    # ADMIN - Administrative ticket operations
    adminUpdateTicket(ticketId: ID!, input: AdminTicketUpdateInput!): TicketMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    regenerateTicketQrCode(ticketId: ID!): TicketMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    bulkCancelTickets(ticketIds: [ID!]!, reason: String!): BulkOperationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # REFUND REQUEST MUTATIONS
    # MOBILE - Customer requests, ADMIN - Approval workflow
    # ========================================================================

    # MOBILE - Customer initiates refund request
    createUserRefundRequest(input: CreateRefundRequestInput!): CreateRefundRequestMutationResponse! @auth(requires: CUSTOMER) @tag(name: "mobile")
    # ADMIN - Admin-initiated refund
    createAdminRefundRequest(ticketId: ID!, reason: String!, bypassApproval: Boolean): RefundRequestMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    # ADMIN - Refund approval workflow
    # NOTE: Actor IDs (reviewerId, processedBy, etc.) extracted from JWT - OWASP A01:2021
    approveRefundRequest(refundRequestId: ID!, reviewComments: String): ApproveRefundRequestMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    rejectRefundRequest(refundRequestId: ID!, rejectionReason: String!): RejectRefundRequestMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    processRefundRequest(refundRequestId: ID!): ProcessRefundRequestMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    cancelRefundRequest(refundRequestId: ID!, reason: String!): RefundRequestMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")
    bulkApproveRefunds(refundRequestIds: [ID!]!): BulkOperationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ========================================================================
    # FINANCIAL TRANSACTION MUTATIONS - REMOVED
    # Replaced by:
    # - PaymentAttempt mutations for payment lifecycle
    # - JournalEntry mutations for accounting
    # ========================================================================

    # ========================================================================
    # PAYMENT ATTEMPT MUTATIONS
    # ADMIN/INTERNAL - Payment attempt lifecycle management
    # ========================================================================

    # INTERNAL - Initiate payment (called by checkout flow)
    initiatePaymentAttempt(input: InitiatePaymentAttemptInput!): PaymentAttemptMutationResponse! @auth(requires: INTERNAL) @tag(name: "internal")
    # INTERNAL - Retry failed payment
    retryPaymentAttempt(depositId: String!): PaymentAttemptMutationResponse! @auth(requires: INTERNAL) @tag(name: "internal")

    # INTERNAL - Webhook processing (called by PawaPay webhook handler)
    processPaymentWebhook(input: ProcessPaymentWebhookInput!): PaymentAttemptMutationResponse! @auth(requires: INTERNAL) @tag(name: "internal")

    # ADMIN - Manual status verification with gateway
    verifyPaymentWithGateway(depositId: String!): PaymentAttemptMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Mark fulfillment complete
    markPaymentFulfilled(input: MarkPaymentFulfilledInput!): PaymentAttemptMutationResponse! @auth(requires: INTERNAL) @tag(name: "internal")

    # ADMIN - Cancel payment
    cancelPaymentAttempt(depositId: String!, reason: String!): PaymentAttemptMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Add note for audit trail
    # NOTE: author extracted from JWT authentication (OWASP A01:2021 compliance)
    addPaymentAttemptNote(depositId: String!, note: String!): PaymentAttemptMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # ADMIN - Set review status for investigation
    # NOTE: reviewedBy extracted from JWT authentication (OWASP A01:2021 compliance)
    setPaymentAttemptReviewStatus(depositId: String!, reviewStatus: String!, notes: String): PaymentAttemptMutationResponse! @auth(requires: ADMIN) @tag(name: "admin")

    # INTERNAL - Scheduled job operations
    pollPendingPayments: Int! @auth(requires: INTERNAL) @tag(name: "internal")
    expireTimedOutPayments: Int! @auth(requires: INTERNAL) @tag(name: "internal")

    # ========================================================================
    # ESCROW ACCOUNT MUTATIONS
    # ADMIN - Escrow account management
    # ========================================================================

    # INTERNAL - Auto-create escrow on event publish
    createEscrowAccount(input: CreateEscrowAccountInput!): EscrowAccountMutationResponse! @tag(name: "internal")
    # ADMIN - Escrow account management
    updateEscrowAccountStatus(accountId: ID!, status: EscrowAccountStatus!, reason: String): EscrowAccountMutationResponse! @tag(name: "admin")
    lockEscrowAccount(accountId: ID!, lockUntil: DateTime!, reason: String!): EscrowAccountMutationResponse! @tag(name: "admin")
    unlockEscrowAccount(accountId: ID!, reason: String!): EscrowAccountMutationResponse! @tag(name: "admin")
    markPayoutEligible(accountId: ID!): EscrowAccountMutationResponse! @tag(name: "admin")
    closeEscrowAccount(accountId: ID!, reason: String!): EscrowAccountMutationResponse! @tag(name: "admin")

    # ========================================================================
    # PAYOUT REQUEST MUTATIONS
    # ORGANIZER - Request payouts, ADMIN - Approve/process
    # ========================================================================

    # ORGANIZER - Request payout of event revenue
    # NOTE: Actor IDs extracted from JWT authentication - OWASP A01:2021
    createPayoutRequest(input: CreatePayoutRequestInput!): CreatePayoutRequestMutationResponse! @tag(name: "organizer")
    # ADMIN - Payout approval workflow
    approvePayoutRequest(payoutRequestId: ID!, notes: String): ApprovePayoutRequestMutationResponse! @tag(name: "admin")
    rejectPayoutRequest(payoutRequestId: ID!, rejectionReason: String!): RejectPayoutRequestMutationResponse! @tag(name: "admin")
    processPayoutRequest(payoutRequestId: ID!): ProcessPayoutRequestMutationResponse! @tag(name: "admin")
    # ADMIN - Complete payout after bank transfer (records accounting entries)
    completePayoutRequest(payoutRequestId: ID!, bankReference: String!): PayoutRequestMutationResponse! @tag(name: "admin")
    # ORGANIZER - Cancel own payout request
    cancelPayoutRequest(payoutRequestId: ID!, reason: String!): RejectPayoutRequestMutationResponse! @tag(name: "organizer") @tag(name: "admin")
    retryPayoutRequest(payoutRequestId: ID!): PayoutRequestMutationResponse! @tag(name: "admin")

    # ADMIN - Payout Recovery Operations
    resumePayoutRequest(payoutRequestId: ID!): PayoutRequestMutationResponse! @tag(name: "admin")
    markPayoutForReview(payoutRequestId: ID!, issueType: PayoutIssueType!, notes: String): PayoutRequestMutationResponse! @tag(name: "admin")
    resolvePayoutIssue(payoutRequestId: ID!, resolutionType: PayoutResolutionType!, notes: String!, newBankAccountId: ID): PayoutRequestMutationResponse! @tag(name: "admin")
    bulkRetryFailedPayouts(payoutRequestIds: [ID!]!): BulkPayoutOperationResponse! @tag(name: "admin")
    bulkMarkPayoutsForReview(payoutRequestIds: [ID!]!, issueType: PayoutIssueType!, notes: String): BulkPayoutOperationResponse! @tag(name: "admin")
    escalatePayoutRequest(payoutRequestId: ID!, reason: String!): PayoutRequestMutationResponse! @tag(name: "admin")

    # ========================================================================
    # BANK ACCOUNT MUTATIONS
    # ORGANIZER - Manage own bank accounts, ADMIN - Verify
    # ========================================================================

    # ORGANIZER - Bank account CRUD
    # NOTE: organizerId/verifiedBy extracted from JWT authentication (OWASP A01:2021 compliance)
    createBankAccount(input: CreateBankAccountInput!): CreateBankAccountMutationResponse! @tag(name: "organizer")
    updateBankAccount(id: ID!, input: UpdateBankAccountInput!): UpdateBankAccountMutationResponse! @tag(name: "organizer")
    deleteBankAccount(id: ID!): DeleteBankAccountMutationResponse! @tag(name: "organizer")
    setDefaultBankAccount(id: ID!): UpdateBankAccountMutationResponse! @tag(name: "organizer")
    # ADMIN - Bank account verification
    verifyBankAccount(id: ID!): VerifyBankAccountMutationResponse! @tag(name: "admin")

    # ========================================================================
    # RESERVATION MUTATIONS
    # MOBILE - Ticket checkout flow
    # ========================================================================

    # MOBILE - Customer checkout flow (userId extracted from JWT for security)
    reserveTickets(input: ReserveTicketsInput!): TicketReservation! @tag(name: "mobile")
    completeReservation(input: CompleteReservationInput!): [Ticket!]! @tag(name: "mobile")
    cancelReservation(reservationId: ID!): Boolean! @tag(name: "mobile")
    extendReservation(reservationId: ID!, minutes: Int!): TicketReservation! @tag(name: "mobile")
    # ADMIN - Force expire stuck reservations
    forceExpireReservation(reservationId: ID!): Boolean! @tag(name: "admin")

    # ========================================================================
    # PROMO CODE MUTATIONS
    # ORGANIZER - Promo code management for marketing
    # ========================================================================

    # ORGANIZER - Promo code CRUD
    # NOTE: createdBy extracted from JWT authentication (OWASP A01:2021 compliance)
    createPromoCode(input: CreatePromoCodeInput!): PromoCode! @tag(name: "organizer")
    updatePromoCode(id: ID!, input: UpdatePromoCodeInput!): PromoCode! @tag(name: "organizer")
    activatePromoCode(id: ID!): PromoCode! @tag(name: "organizer")
    deactivatePromoCode(id: ID!): PromoCode! @tag(name: "organizer")
    deletePromoCode(id: ID!): DeleteMutationResponse! @tag(name: "organizer")

    # ========================================================================
    # FINANCIAL ENGINE MUTATIONS - Double-Entry Bookkeeping
    # ADMIN-ONLY - Core accounting infrastructure
    # ========================================================================

    # ADMIN - Chart of Accounts management
    createChartOfAccountsEntry(input: CreateChartOfAccountsInput!): ChartOfAccountsMutationResponse! @tag(name: "admin")
    updateChartOfAccountsEntry(id: ID!, input: CreateChartOfAccountsInput!): ChartOfAccountsMutationResponse! @tag(name: "admin")
    deactivateChartOfAccountsEntry(id: ID!): ChartOfAccountsMutationResponse! @tag(name: "admin")
    seedChartOfAccounts: Boolean! @tag(name: "admin")

    # ADMIN - Journal Entry management
    # NOTE: Actor IDs (postedBy, reversedBy) extracted from JWT authentication (OWASP A01:2021 compliance)
    createJournalEntry(input: CreateJournalEntryInput!): JournalEntryMutationResponse! @tag(name: "admin")
    postJournalEntry(id: ID!): JournalEntryMutationResponse! @tag(name: "admin")
    reverseJournalEntry(id: ID!, reason: String!): JournalEntryMutationResponse! @tag(name: "admin")

    # ADMIN - Platform Account management
    createPlatformAccount(accountType: PlatformAccountType!, name: String!, currency: String!): PlatformAccountMutationResponse! @tag(name: "admin")
    creditPlatformAccount(id: ID!, amount: BigDecimal!, description: String!): PlatformAccountMutationResponse! @tag(name: "admin")
    debitPlatformAccount(id: ID!, amount: BigDecimal!, description: String!): PlatformAccountMutationResponse! @tag(name: "admin")

    # ========================================================================
    # CHARGEBACK MUTATIONS
    # ADMIN-ONLY - Chargeback lifecycle management
    # ========================================================================

    # ADMIN - Chargeback lifecycle management
    receiveChargeback(input: ReceiveChargebackInput!): ChargebackMutationResponse! @tag(name: "admin")
    startChargebackReview(id: ID!, notes: String): ChargebackMutationResponse! @tag(name: "admin")
    acceptChargeback(id: ID!, reason: String): ChargebackMutationResponse! @tag(name: "admin")
    disputeChargeback(id: ID!, input: DisputeChargebackInput!): ChargebackMutationResponse! @tag(name: "admin")
    recordChargebackOutcome(id: ID!, won: Boolean!, notes: String): ChargebackMutationResponse! @tag(name: "admin")
    recoverChargebackFunds(id: ID!, input: RecoverChargebackInput!): ChargebackMutationResponse! @tag(name: "admin")

    # ========================================================================
    # RECONCILIATION MUTATIONS
    # ADMIN-ONLY - Reconciliation engine
    # ========================================================================

    # ADMIN - Reconciliation management
    startReconciliation(input: StartReconciliationInput!): ReconciliationMutationResponse! @tag(name: "admin")
    resolveReconciliationItem(runId: ID!, input: ResolveReconciliationItemInput!): ReconciliationMutationResponse! @tag(name: "admin")
    completeReconciliation(runId: ID!, notes: String): ReconciliationMutationResponse! @tag(name: "admin")
    failReconciliation(runId: ID!, reason: String!): ReconciliationMutationResponse! @tag(name: "admin")

    # ADMIN - Escrow-Journal Cross-Verification
    # Verifies that EventEscrowAccount balances match journal entry calculated balances
    verifyEscrowJournalConsistency(eventId: ID!): EscrowJournalVerificationResponse! @tag(name: "admin")

    """
    Records a gateway settlement in the accounting system.

    Called when:
    1. Gateway webhook confirms settlement completed
    2. Admin manually records a settlement from bank statement
    3. Reconciliation process confirms matched transactions

    Accounting Entry (IN/OUT):
    - DR Bank Account (1011)        - IN: Money received in bank
    - DR Gateway Fees Expense (5010) - IN: Fee cost to platform
    - CR Gateway Receivable (1021)  - OUT: Receivable cleared
    """
    recordGatewaySettlement(input: RecordGatewaySettlementInput!): JournalEntryMutationResponse! @tag(name: "admin")

}

