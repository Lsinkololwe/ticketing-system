# ============================================================================
# BOOKING SERVICE - GraphQL Federation 2 Subgraph Schema
# ============================================================================
#
# This service is the OWNER of Ticket, Payment, and Financial entities.
# It manages everything related to ticket purchases, payments, and refunds.
#
# FEDERATION CONCEPTS USED:
# - @key: Marks Ticket as a federated entity
# - @external: References fields owned by other services
# - @requires: Declares dependencies on external fields for computed values
# - @provides: Optimization hint for fields we can provide from cached data
# - @shareable: Allows sharing of certain fields
# - @tag: Client-specific schema filtering for code generation
#
# OWNERSHIP:
# - Ticket (primary owner)
# - PaymentAttempt, EventEscrowAccount, RefundRequest (exclusive)
# - JournalEntry for double-entry bookkeeping records
# - PayoutRequest, BankAccount (exclusive)
# - TicketReservation, PromoCode (exclusive)
#
# TYPE EXTENSIONS (We ADD fields to types owned by other services):
# - Event: We add tickets, ticketsSold, revenue, soldOut, ticketsAvailable
# - User: We add purchasedTickets, totalSpent
#
# SCHEMA ORGANIZATION:
# 1. Federation directives & Scalars
# 2. Enums
# 3. Entity stubs & extensions
# 4. Primary types (Ticket, Financial, Escrow, etc.)
# 5. Feature types (Reservation, PromoCode)
# 6. Supporting types
# 7. Statistics types
# 8. Pagination types
# 9. Input types
# 10. Mutation response types
# 11. Subscription payload types
# 12. Query type (bottom)
# 13. Mutation type (bottom)
# 14. Subscription type (very bottom)
#
# ============================================================================
# CLIENT-SPECIFIC TAGGING STRATEGY
# ============================================================================
# This schema uses @tag directives for operation-based code generation.
# Tags indicate which client types should include specific fields/operations:
#
# - (no tag) = PUBLIC - Available to all clients
# - @tag(name: "mobile") = Mobile app consumer features
# - @tag(name: "organizer") = Organizer dashboard features
# - @tag(name: "admin") = Platform administrator features
# - @tag(name: "internal") = Service-to-service communication only
#
# BOOKING SERVICE TAGGING PRINCIPLES:
# - Ticket purchase flow → mobile
# - Ticket/payment management → organizer (own events), admin (all events)
# - Financial reporting/escrow → admin
# - Statistics → admin (platform-wide), organizer (own events)
# ============================================================================

# ============================================================================
# SECTION 1: FEDERATION 2 SCHEMA EXTENSION
# ============================================================================
extend schema @link(
    url: "https://specs.apollo.dev/federation/v2.9",
    import: ["@key", "@shareable", "@external", "@requires", "@provides", "@extends", "@inaccessible", "@tag"]
)

# ============================================================================
# SECTION 1.1: AUTHORIZATION DIRECTIVE
# ============================================================================
# Role enum and @auth directive are defined in shared-library/auth.graphqls
# and automatically loaded. Use @auth(requires: ROLE) on operations.
# ============================================================================

# ============================================================================
# SECTION 2: CUSTOM SCALARS
# ============================================================================
scalar DateTime
scalar BigDecimal
scalar JSON

# ============================================================================
# SECTION 3: ENUMS
# ============================================================================

# Ticket lifecycle status
enum TicketStatus {
    PENDING_PAYMENT    # Ticket reserved, awaiting payment
    PURCHASED          # Payment received
    CONFIRMED          # Ticket confirmed and issued
    VALIDATED          # Scanned/checked at venue
    USED               # Fully used (for multi-entry tickets)
    EXPIRED            # Past event date, never used
    CANCELLED          # Cancelled before event
    REFUNDED           # Refund processed
    PAYMENT_FAILED     # Payment attempt failed
    REFUND_PENDING     # Queued for refund (e.g., event cancelled)
}

# Ticket category (shared value type with Catalog Service)
enum TicketCategory {
    GENERAL
    PRE_SALE
    VIP
    VVIP
    PREMIUM
    EARLY_BIRD
    STUDENT
    SENIOR
    GROUP
    CORPORATE
    SPONSOR
    FREE
}

# Financial transaction status
enum TransactionStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
    CANCELLED
    REVERSED
    ROLLED_BACK
    FULFILLED
    RETRYING
    TIMED_OUT
    PENDING_VERIFICATION
}

# Transaction issue types for recovery operations
enum TransactionIssueType @tag(name: "admin") {
    PAYMENT_TIMEOUT           # Payment gateway timeout
    WEBHOOK_MISSED            # Callback not received
    AMOUNT_MISMATCH           # Payment amount doesn't match expected
    DUPLICATE_TRANSACTION     # Potential duplicate detected
    PROVIDER_ERROR            # Payment provider returned error
    NETWORK_FAILURE           # Network communication failure
    VALIDATION_FAILURE        # Transaction validation failed
    MANUAL_REVIEW_REQUIRED    # Flagged for manual review
    RECONCILIATION_NEEDED     # Needs reconciliation with external system
    OTHER                     # Other unclassified issue
}

# How transaction issues are resolved
enum TransactionResolutionType @tag(name: "admin") {
    AUTO_RESOLVED             # System automatically resolved
    MANUAL_APPROVAL           # Admin manually approved
    MANUAL_REJECTION          # Admin manually rejected
    RETRIED_SUCCESS           # Successfully retried
    REFUNDED                  # Refunded to customer
    WRITTEN_OFF               # Written off as loss
    RECONCILED                # Reconciled with external system
    ESCALATED                 # Escalated to higher authority
}

# Review status for transactions requiring attention
enum TransactionReviewStatus @tag(name: "admin") {
    NONE                      # No review needed
    PENDING_REVIEW            # Waiting for review
    UNDER_REVIEW              # Currently being reviewed
    REVIEWED                  # Review completed
    ESCALATED                 # Escalated for higher review
}

# Payment methods supported
enum PaymentMethod {
    MOBILE_MONEY       # MTN, Airtel, Zamtel
    CARD               # Visa, Mastercard
    BANK_TRANSFER      # Direct bank transfer
}

# Refund request status
enum RefundRequestStatus {
    PENDING
    APPROVED
    PROCESSING
    COMPLETED
    REJECTED
    FAILED
    CANCELLED
}

# How the refund was initiated
enum RefundRequestType {
    USER_REQUESTED
    ADMIN_INITIATED
    SYSTEM_AUTOMATIC
    EVENT_CANCELLED
    TICKET_EXPIRED
}

# Escrow account status
enum EscrowAccountStatus {
    CREATED
    ACTIVE
    LOCKED
    PAYOUT_ELIGIBLE
    PROCESSING_PAYOUT
    CLOSED
    CANCELLED
}

# Payout request status
enum PayoutRequestStatus {
    PENDING
    APPROVED
    PROCESSING
    COMPLETED
    FAILED
    REJECTED
    CANCELLED
}

# Payout method types
enum PayoutMethod {
    BANK_TRANSFER
    MOBILE_MONEY
    CHEQUE
}

# Payout issue types for recovery operations
enum PayoutIssueType @tag(name: "admin") {
    BANK_REJECTED             # Bank rejected the payout
    INVALID_ACCOUNT_DETAILS   # Account details are invalid
    INSUFFICIENT_ESCROW       # Not enough funds in escrow
    COMPLIANCE_HOLD           # Held for compliance review
    SUSPECTED_FRAUD           # Flagged for potential fraud
    TECHNICAL_ERROR           # Technical failure during processing
    PROVIDER_ERROR            # Payment provider error
    TIMEOUT                   # Payout processing timed out
    DUPLICATE_REQUEST         # Potential duplicate payout
    OTHER                     # Other unclassified issue
}

# How payout issues are resolved
enum PayoutResolutionType @tag(name: "admin") {
    AUTO_RESOLVED             # System automatically resolved
    MANUAL_APPROVAL           # Admin manually approved
    MANUAL_REJECTION          # Admin manually rejected
    RETRIED_SUCCESS           # Successfully retried
    ACCOUNT_UPDATED           # Bank account details corrected
    REFUNDED_TO_ESCROW        # Amount returned to escrow
    WRITTEN_OFF               # Written off as loss
    ESCALATED                 # Escalated to higher authority
}

# Review status for payout requests requiring attention
enum PayoutReviewStatus @tag(name: "admin") {
    NONE                      # No review needed
    PENDING_REVIEW            # Waiting for review
    UNDER_REVIEW              # Currently being reviewed
    REVIEWED                  # Review completed
    ESCALATED                 # Escalated for higher review
}

# Reservation status
enum ReservationStatus {
    ACTIVE
    CONVERTED
    EXPIRED
    CANCELLED
}

# Promo code discount type
enum DiscountType {
    PERCENTAGE
    FIXED_AMOUNT
}

# Time unit for reporting
enum TimeUnit {
    HOUR
    DAY
    WEEK
    MONTH
}

# Export format
enum ExportFormat {
    CSV
    PDF
    EXCEL
    JSON
}

# ============================================================================
# FINANCIAL ENGINE ENUMS (Double-Entry Bookkeeping)
# ============================================================================

# Primary account classification in Chart of Accounts
enum AccountType @tag(name: "admin") {
    ASSET
    LIABILITY
    EQUITY
    REVENUE
    EXPENSE
}

# Detailed account sub-classification
enum AccountSubType @tag(name: "admin") {
    BANK_ACCOUNT
    GATEWAY_RECEIVABLE
    COMMISSION_RECEIVABLE
    CHARGEBACK_RECEIVABLE
    ESCROW_PAYABLE
    PAYOUTS_PAYABLE
    REFUNDS_PAYABLE
    TAX_PAYABLE
    FEES_PAYABLE
    DEFERRED_REVENUE
    RETAINED_EARNINGS
    RESERVE
    COMMISSION_REVENUE
    FEE_REVENUE
    GATEWAY_FEES
    CHARGEBACK_LOSS
    CHARGEBACK_FEES
    BAD_DEBT
}

# Normal balance direction for accounts
enum BalanceDirection @tag(name: "admin") {
    DEBIT
    CREDIT
}

# Journal entry type
enum JournalEntryType @tag(name: "admin") {
    STANDARD
    ADJUSTMENT
    REVERSAL
}

# Journal entry lifecycle status
enum JournalEntryStatus @tag(name: "admin") {
    DRAFT
    POSTED
    REVERSED
}

# Reconciliation type
enum ReconciliationType @tag(name: "admin") {
    GATEWAY
    BANK
    ESCROW
    ESCROW_JOURNAL
}

# Escrow-Journal verification status
enum EscrowJournalVerificationStatus @tag(name: "admin") {
    CONSISTENT                # Balances match
    BALANCE_MISMATCH          # Both exist but balances don't match
    MISSING_JOURNAL_ACCOUNT   # Escrow exists but no journal account
    ORPHANED_JOURNAL_ACCOUNT  # Journal account exists but no escrow
    NOT_FOUND                 # Neither exists for this event
}

# Reconciliation run status
enum ReconciliationStatus @tag(name: "admin") {
    RUNNING
    COMPLETED
    REQUIRES_REVIEW
    FAILED
}

# Reconciliation item matching status
enum ReconciliationItemStatus @tag(name: "admin") {
    MATCHED
    UNMATCHED_EXTERNAL
    UNMATCHED_INTERNAL
    AMOUNT_MISMATCH
}

# Chargeback reason categories
enum ChargebackReason @tag(name: "admin") {
    FRAUD
    NOT_RECEIVED
    NOT_AS_DESCRIBED
    DUPLICATE
    CANCELLED
    OTHER
}

# Chargeback lifecycle status
enum ChargebackStatus @tag(name: "admin") {
    RECEIVED
    UNDER_REVIEW
    ACCEPTED
    DISPUTED
    WON
    LOST
}

# Chargeback recovery status
enum RecoveryStatus @tag(name: "admin") {
    NOT_STARTED
    IN_PROGRESS
    RECOVERED
    WRITTEN_OFF
}

# Source of chargeback recovery funds
enum ChargebackFundSource @tag(name: "admin") {
    ORGANIZER_ESCROW
    ORGANIZER_FUTURE
    PLATFORM_RESERVE
    WRITE_OFF
}

# Platform account types
enum PlatformAccountType @tag(name: "admin") {
    OPERATING
    RESERVE
    TAX_HOLDING
}

# Payment Attempt Status - Tracks the lifecycle of a payment operation
# Used by PaymentAttempt to track PawaPay mobile money payment lifecycle
enum PaymentAttemptStatus @tag(name: "admin") {
    CREATED                # Record created, PawaPay API not yet called
    PENDING_APPROVAL       # PawaPay accepted, waiting for customer to approve on phone
    PROCESSING             # PawaPay is processing the payment
    CONFIRMED              # Payment confirmed by PawaPay, ready for fulfillment
    COMPLETED              # Fulfillment done (escrow credited, commission created, journal posted)
    FAILED                 # Payment failed (customer declined, insufficient funds, etc.)
    REJECTED               # PawaPay rejected our request (invalid phone, unsupported provider)
    EXPIRED                # 15-minute timeout reached without confirmation
    CANCELLED              # Cancelled by user or system
}

# ============================================================================
# SECTION 4: ENTITY STUBS (Owned by other services)
# ============================================================================

# User stub - owned by Identity Service
# Includes fields we can @provides from cached Ticket buyer data
# NOTE: @external field types MUST match the owning service (identity)
type User @key(fields: "id", resolvable: false) {
    id: ID!
    # These fields can be provided from Ticket's cached buyer data
    # Types must match identity-service: fullName!, email!, phoneNumber (nullable)
    fullName: String! @external
    email: String! @external
    phoneNumber: String @external
}

# Event stub - owned by Catalog Service
type Event @key(fields: "id", resolvable: false) {
    id: ID!
}

# ============================================================================
# SECTION 5: ENTITY EXTENSIONS
# These fields are added to types owned by other services
# ============================================================================

# User extension - add booking-related fields
extend type User @key(fields: "id") {
    # MOBILE - Customer's purchased tickets (my tickets list)
    purchasedTickets: [Ticket!]! @tag(name: "mobile")
    # ORGANIZER/ADMIN - Financial tracking for customer spending
    totalSpent: BigDecimal! @tag(name: "organizer") @tag(name: "admin")
    # MOBILE - Quick count for my tickets badge
    activeTicketCount: Int! @tag(name: "mobile")
}

# Event extension - add ticket/sales-related fields
extend type Event @key(fields: "id") {
    # External fields from Catalog Service (needed for computation)
    totalCapacity: Int! @external
    title: String! @external
    eventDateTime: DateTime! @external
    organizerId: String! @external

    # ORGANIZER/ADMIN - Full ticket list for event management
    tickets: [Ticket!]! @tag(name: "organizer") @tag(name: "admin")
    # ORGANIZER/ADMIN - Sales metrics for dashboard
    ticketsSold: Int! @tag(name: "organizer") @tag(name: "admin")
    revenue: BigDecimal! @tag(name: "organizer") @tag(name: "admin")

    # PUBLIC - Availability info displayed on event listings
    ticketsAvailable: Int! @requires(fields: "totalCapacity")
    soldOut: Boolean! @shareable @requires(fields: "totalCapacity")
    # ORGANIZER/ADMIN - Sales percentage for performance tracking
    salesPercentage: Float! @requires(fields: "totalCapacity") @tag(name: "organizer") @tag(name: "admin")
}

# ============================================================================
# SECTION 6: PRIMARY TYPES
# ============================================================================

# ------------------------------
# TICKET (Primary Entity)
# Core booking entity - different fields exposed to different clients
# ------------------------------
type Ticket @key(fields: "id") {
    # ---------------------------------------------------------------------------
    # PUBLIC FIELDS - Available to all clients including mobile
    # Core ticket identification and display information
    # ---------------------------------------------------------------------------
    id: ID!
    ticketNumber: String!

    # Event reference - public for ticket display
    event: Event! @provides(fields: "title eventDateTime organizerId")
    eventId: String!

    # Buyer reference - only own buyer sees full details
    # @provides optimization: We cache buyer name/email/phone on Ticket for display
    buyer: User! @provides(fields: "fullName email phoneNumber")
    # ORGANIZER/ADMIN - Buyer ID for attendee management (privacy protection)
    buyerId: String! @tag(name: "organizer") @tag(name: "admin")

    # INTERNAL - Organizer and Organization IDs for multi-tenant tracking
    # Used for authorization, reporting, and financial compliance
    organizerId: String @tag(name: "internal")
    organizationId: String @tag(name: "internal")

    # Cached event data - public for ticket display
    eventTitle: String!
    eventDate: String
    eventLocationName: String
    eventLocationAddress: String

    # ---------------------------------------------------------------------------
    # ORGANIZER/ADMIN FIELDS - Buyer PII for attendee management
    # Protected for privacy - only event organizers and admins can see buyer details
    # ---------------------------------------------------------------------------
    buyerName: String @tag(name: "organizer") @tag(name: "admin")
    buyerEmail: String @tag(name: "organizer") @tag(name: "admin")
    buyerPhone: String @tag(name: "organizer") @tag(name: "admin")

    # ---------------------------------------------------------------------------
    # PUBLIC FIELDS - Ticket details shown to ticket holder
    # ---------------------------------------------------------------------------
    ticketCategory: TicketCategory
    ticketCategoryCode: String
    ticketCategoryName: String
    price: BigDecimal!
    currency: String!
    status: TicketStatus!
    quantity: Int

    # ---------------------------------------------------------------------------
    # TICKET LIFECYCLE - Mixed visibility
    # ---------------------------------------------------------------------------
    purchaseDate: DateTime
    validFrom: DateTime
    validUntil: DateTime
    # ORGANIZER/ADMIN - Entry validation tracking for venue management
    validatedAt: DateTime @tag(name: "organizer") @tag(name: "admin")
    validatedBy: String @tag(name: "organizer") @tag(name: "admin")  # Scanner ID who validated
    usedAt: DateTime
    cancelledAt: DateTime
    cancellationReason: String
    refundedAt: DateTime
    refundReason: String

    # PUBLIC - QR code for ticket holder's mobile app
    qrCode: String
    barcode: String

    # ---------------------------------------------------------------------------
    # INTERNAL/ADMIN - Transaction and financial tracking
    # ---------------------------------------------------------------------------
    # INTERNAL - Correlation ID for distributed tracing
    correlationId: String @tag(name: "internal")
    paymentReference: String @tag(name: "organizer") @tag(name: "admin")

    # ORGANIZER/ADMIN - Financial breakdown for revenue tracking
    commissionRate: BigDecimal @tag(name: "organizer") @tag(name: "admin")
    commissionAmount: BigDecimal @tag(name: "organizer") @tag(name: "admin")
    netAmount: BigDecimal @tag(name: "organizer") @tag(name: "admin")
    paymentInfo: PaymentInfo @tag(name: "organizer") @tag(name: "admin")
    refundInfo: RefundInfo @tag(name: "organizer") @tag(name: "admin")

    # ---------------------------------------------------------------------------
    # INTERNAL - Audit fields for system tracking
    # ---------------------------------------------------------------------------
    createdAt: DateTime @tag(name: "internal")
    updatedAt: DateTime @tag(name: "internal")
    isActive: Boolean!
}

# ------------------------------
# FINANCIAL TRANSACTION - DEPRECATED / REMOVED
# The FinancialTransaction type has been removed in favor of:
# - PaymentAttempt: Tracks the operational lifecycle of payments through PawaPay
# - JournalEntry: Records accounting entries for double-entry bookkeeping
#
# For payment tracking, use PaymentAttempt queries
# For accounting/financial records, use JournalEntry queries
# ------------------------------

# ------------------------------
# PAYMENT ATTEMPT
# ADMIN-ONLY - Tracks the complete lifecycle of a payment operation
# This is the OPERATIONAL layer tracking HOW a payment progresses through PawaPay,
# distinct from JournalEntry which records THAT money moved in the accounting ledger.
# ------------------------------
type PaymentAttempt @tag(name: "admin") {
    id: ID!
    # Identity & Correlation
    depositId: String!                    # UUID sent to PawaPay (idempotency key)
    attemptNumber: String!                # Human-readable: PAY-{YYYYMMDD}-{XXXXX}
    correlationId: String                 # Links related operations

    # Business Entity References
    ticketId: String!
    eventId: String
    organizerId: String
    organizationId: String                # Multi-tenant tracking
    buyerId: String!
    clientReferenceId: String             # Ticket number sent to PawaPay

    # Payment Details
    amount: BigDecimal!
    currency: String!
    provider: String!                     # MTN_MOMO_ZMB, AIRTEL_OAPI_ZMB, ZAMTEL_ZMB
    payerPhone: String!
    customerMessage: String

    # Status Tracking
    status: PaymentAttemptStatus!
    providerStatus: String                # PawaPay's status (ACCEPTED, PROCESSING, COMPLETED, FAILED)
    providerTransactionId: String         # PawaPay's transaction ID (set after COMPLETED)
    country: String

    # Failure Tracking
    failureCode: String
    failureMessage: String
    customerErrorMessage: String

    # API Interaction Tracking
    apiCalledAt: DateTime
    apiRespondedAt: DateTime
    apiHttpStatus: Int
    apiDurationMs: Int

    # Webhook Tracking
    webhookReceivedAt: DateTime
    webhookProcessed: Boolean!
    webhookSignatureValid: Boolean
    webhookSourceIp: String

    # Polling & Recovery
    pollCount: Int!
    lastPolledAt: DateTime
    lastPollResult: String
    lastPollStatus: String
    retryCount: Int!
    nextRetryAt: DateTime
    lastError: String

    # Fulfillment Tracking
    fulfilled: Boolean!
    fulfilledAt: DateTime
    journalEntryId: String
    commissionId: String
    escrowTransactionId: String

    # Verification Flags (OWASP compliance)
    verifiedBeforeFulfillment: Boolean!
    verifiedAt: DateTime
    amountVerified: Boolean!

    # Security & Audit
    clientIpAddress: String
    sessionId: String
    requestId: String

    # Review
    reviewStatus: String
    reviewedBy: String
    reviewedAt: DateTime
    reviewNotes: String
    notes: String

    # Timestamps
    createdAt: DateTime
    updatedAt: DateTime
    expiresAt: DateTime
}

# ------------------------------
# EVENT ESCROW ACCOUNT
# ADMIN-ONLY - Platform escrow management for event revenue holding
# Escrow accounts hold ticket revenue until event completion
# ------------------------------
type EventEscrowAccount @tag(name: "admin") {
    id: ID!
    accountNumber: String!
    eventId: String!
    eventTitle: String
    organizerId: String!
    organizerName: String
    currentBalance: BigDecimal!
    totalDeposits: BigDecimal!
    totalWithdrawals: BigDecimal!
    totalRefunds: BigDecimal!
    totalCommissions: BigDecimal!
    pendingWithdrawals: BigDecimal
    currency: String!
    status: EscrowAccountStatus!
    lockUntil: DateTime
    lockReason: String
    payoutEligibleAt: DateTime
    closedAt: DateTime
    closedReason: String
    createdAt: DateTime
    updatedAt: DateTime
}

# ------------------------------
# BANK ACCOUNT
# ORGANIZER/ADMIN - Bank account details for payout processing
# Organizers manage their own bank accounts, admins can view/verify all
# ------------------------------
type BankAccount @tag(name: "organizer") @tag(name: "admin") {
    id: ID!
    organizerId: String!
    organizationId: String               # Multi-tenant tracking
    accountHolderName: String!
    bankName: String!
    bankCode: String
    branchName: String
    branchCode: String
    accountNumber: String!
    accountType: String
    currency: String!
    swiftCode: String
    isDefault: Boolean!
    isVerified: Boolean!
    verifiedAt: DateTime
    verifiedBy: String
    status: String!
    createdAt: DateTime
    updatedAt: DateTime
}

# ------------------------------
# PAYOUT REQUEST
# ORGANIZER/ADMIN - Payout request workflow
# Organizers create and track their payout requests, admins approve/process
# ------------------------------
type PayoutRequest @tag(name: "organizer") @tag(name: "admin") {
    id: ID!
    requestId: String!
    organizerId: String!
    organizationId: String               # Multi-tenant tracking
    organizerName: String
    eventId: String
    eventTitle: String
    escrowAccountId: String!
    bankAccountId: String!
    bankAccount: BankAccount
    requestedAmount: BigDecimal!
    platformFee: BigDecimal
    processingFee: BigDecimal
    taxAmount: BigDecimal
    netPayoutAmount: BigDecimal!
    currency: String!
    status: PayoutRequestStatus!
    payoutMethod: PayoutMethod
    requestedAt: DateTime!
    requestedBy: String!
    approvedAt: DateTime
    approvedBy: String
    rejectedAt: DateTime
    rejectedBy: String
    rejectionReason: String
    processedAt: DateTime
    processedBy: String
    expectedPayoutDate: DateTime
    actualPayoutDate: DateTime
    paymentReference: String
    transactionId: String
    externalTransactionId: String
    bankAccountName: String
    bankName: String
    accountNumber: String
    retryCount: Int
    lastError: String
    notes: String
    metadata: JSON
    createdAt: DateTime
    updatedAt: DateTime

    # Recovery and Review fields (admin only)
    issueType: PayoutIssueType @tag(name: "admin")
    resolutionType: PayoutResolutionType @tag(name: "admin")
    reviewStatus: PayoutReviewStatus @tag(name: "admin")
    isStuck: Boolean @tag(name: "admin")
    stuckReason: String @tag(name: "admin")
    stuckAt: DateTime @tag(name: "admin")
    reviewedBy: String @tag(name: "admin")
    reviewedAt: DateTime @tag(name: "admin")
    reviewNotes: String @tag(name: "admin")
    resolvedBy: String @tag(name: "admin")
    resolvedAt: DateTime @tag(name: "admin")
    resolutionNotes: String @tag(name: "admin")
}

# ------------------------------
# REFUND REQUEST
# ORGANIZER/ADMIN - Refund request workflow
# Organizers see refunds for their events, admins process all refunds
# Mobile users can see their own refund status via ticket.refundInfo
# ------------------------------
type RefundRequest @tag(name: "organizer") @tag(name: "admin") {
    id: ID!
    requestId: String!
    ticketId: String!
    ticketNumber: String!
    eventId: String!
    organizerId: String!
    organizationId: String               # Multi-tenant tracking
    buyerId: String!
    originalTicketPrice: BigDecimal
    refundAmount: BigDecimal!
    refundPercentage: Float
    platformRetains: BigDecimal
    processingFee: BigDecimal
    netRefundAmount: BigDecimal
    currency: String!
    status: RefundRequestStatus!
    requestType: RefundRequestType!
    reason: String!
    additionalNotes: String
    requestedBy: String
    requestedAt: DateTime
    reviewedBy: String
    reviewedAt: DateTime
    reviewComments: String
    rejectionReason: String
    processedAt: DateTime
    processedBy: String
    paymentReference: String
    refundTransactionId: String
    originalPaymentMethod: String
    daysBeforeEvent: Int
    policyApplied: String
    createdAt: DateTime
    updatedAt: DateTime
}

# ============================================================================
# SECTION 7: FEATURE TYPES
# Consumer-facing features for ticket purchasing workflow
# ============================================================================

# ------------------------------
# TICKET RESERVATION
# MOBILE - Temporary ticket holds during checkout flow
# Customers reserve tickets before payment completion
# ------------------------------
type TicketReservation @tag(name: "mobile") {
    id: ID!
    eventId: ID!
    userId: ID!
    items: [ReservationItem!]!
    totalAmount: BigDecimal!
    currency: String!
    status: ReservationStatus!
    expiresAt: DateTime!
    remainingSeconds: Int
    promoCodeApplied: String
    discountAmount: BigDecimal
    createdAt: DateTime!
    updatedAt: DateTime
}

# MOBILE - Items in a reservation
type ReservationItem @tag(name: "mobile") {
    ticketTierId: String!
    tierName: String!
    quantity: Int!
    unitPrice: BigDecimal!
    subtotal: BigDecimal!
}

# ------------------------------
# PROMO CODE
# ORGANIZER - Promo code management for marketing campaigns
# Organizers create and track promo codes for their events
# ------------------------------
type PromoCode @tag(name: "organizer") @tag(name: "admin") {
    id: ID!
    code: String!
    eventId: ID
    organizerId: ID
    discountType: DiscountType!
    discountValue: BigDecimal!
    maxUses: Int
    currentUses: Int!
    validFrom: DateTime
    validUntil: DateTime
    minPurchaseAmount: BigDecimal
    maxDiscountAmount: BigDecimal
    applicableTiers: [String!]
    isActive: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime
}

# MOBILE - Promo code validation result for checkout
type PromoCodeValidation @tag(name: "mobile") {
    valid: Boolean!
    promoCode: PromoCode
    discountAmount: BigDecimal
    errorMessage: String
}

# MOBILE - Refund calculation preview for customer
type RefundCalculation @tag(name: "mobile") {
    ticketId: ID!
    ticketNumber: String!
    eventId: ID!
    eventDate: DateTime!
    originalAmount: BigDecimal!
    daysBeforeEvent: Int!
    refundPercentage: Float!
    refundAmount: BigDecimal!
    commissionRefund: BigDecimal!
    platformRetains: BigDecimal!
    policyApplied: String!
    isEligible: Boolean!
    ineligibleReason: String
}

