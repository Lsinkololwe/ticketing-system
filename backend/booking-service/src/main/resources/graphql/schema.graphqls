# ============================================================================
# SECTION 11: PAGINATION TYPES
# ============================================================================

# Shared type - must have @shareable on all fields for federation
type PaginationInfo @shareable {
    pageNumber: Int @shareable
    pageSize: Int! @shareable
    totalElements: Int @shareable
    totalPages: Int! @shareable
    totalCount: Int @shareable
    currentPage: Int @shareable
    hasNext: Boolean @shareable
    hasPrevious: Boolean @shareable
    hasNextPage: Boolean @shareable
    hasPreviousPage: Boolean @shareable
}

type TicketOffsetPage {
    data: [Ticket!]!
    pagination: PaginationInfo!
}

type EscrowAccountOffsetPage {
    data: [EventEscrowAccount!]!
    pagination: PaginationInfo!
}

type RefundRequestOffsetPage {
    data: [RefundRequest!]!
    pagination: PaginationInfo!
}

type PayoutRequestOffsetPage {
    data: [PayoutRequest!]!
    pagination: PaginationInfo!
}

# TransactionOffsetPage - REMOVED (use PaymentAttemptOffsetPage for payment tracking)

type ReservationOffsetPage {
    data: [TicketReservation!]!
    pagination: PaginationInfo!
}

# Financial Engine Pagination Types
type ChartOfAccountsOffsetPage @tag(name: "admin") {
    data: [ChartOfAccountsEntry!]!
    pagination: PaginationInfo!
}

type JournalEntryOffsetPage @tag(name: "admin") {
    data: [JournalEntry!]!
    pagination: PaginationInfo!
}

type ChargebackOffsetPage @tag(name: "admin") {
    data: [ChargebackRecord!]!
    pagination: PaginationInfo!
}

type ReconciliationRunOffsetPage @tag(name: "admin") {
    data: [ReconciliationRun!]!
    pagination: PaginationInfo!
}

type EscrowTransactionOffsetPage @tag(name: "admin") {
    data: [StandaloneEscrowTransaction!]!
    pagination: PaginationInfo!
}

# ============================================================================
# SECTION 11b: CURSOR PAGINATION TYPES (Relay-style Connections)
# ============================================================================
# Cursor-based pagination following the Relay Connection Specification.
# Used for infinite scroll, mobile apps, and real-time feeds.

# Shared type for cursor-based pagination - must have @shareable for federation
type PageInfo @shareable {
    hasNextPage: Boolean @shareable
    hasPreviousPage: Boolean @shareable
    startCursor: String @shareable
    endCursor: String @shareable
    totalCount: Int @shareable
    totalElements: Int @shareable
    totalPages: Int @shareable
    currentPage: Int @shareable
    pageSize: Int @shareable
    hasNext: Boolean @shareable
    hasPrevious: Boolean @shareable
}

# Ticket cursor pagination
type TicketConnection {
    edges: [TicketEdge!]!
    pageInfo: PageInfo!
    totalCount: Int
}

type TicketEdge {
    cursor: String!
    node: Ticket!
}

# Escrow Account cursor pagination
type EscrowAccountConnection {
    edges: [EscrowAccountEdge!]!
    pageInfo: PageInfo!
    totalCount: Int
}

type EscrowAccountEdge {
    cursor: String!
    node: EventEscrowAccount!
}

# Refund Request cursor pagination
type RefundRequestConnection {
    edges: [RefundRequestEdge!]!
    pageInfo: PageInfo!
    totalCount: Int
}

type RefundRequestEdge {
    cursor: String!
    node: RefundRequest!
}

# Payout Request cursor pagination
type PayoutRequestConnection {
    edges: [PayoutRequestEdge!]!
    pageInfo: PageInfo!
    totalCount: Int
}

type PayoutRequestEdge {
    cursor: String!
    node: PayoutRequest!
}

# Financial Transaction cursor pagination - REMOVED (use PaymentAttempt for payment tracking)


# Reservation cursor pagination
type ReservationConnection {
    edges: [ReservationEdge!]!
    pageInfo: PageInfo!
    totalCount: Int
}

type ReservationEdge {
    cursor: String!
    node: TicketReservation!
}

