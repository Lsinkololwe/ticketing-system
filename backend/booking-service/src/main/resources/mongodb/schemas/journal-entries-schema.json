{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Journal Entries Schema - OWASP Compliant",
    "description": "Core double-entry bookkeeping records with balanced debits and credits",
    "required": [
      "entryNumber",
      "entryDate",
      "description",
      "type",
      "status",
      "lines",
      "currency",
      "createdAt"
    ],
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "entryNumber": {
        "bsonType": "string",
        "pattern": "^JE-\\d{4}-\\d{2}-\\d{5}$",
        "description": "OWASP A03 - Format: JE-YYYY-MM-NNNNN"
      },
      "correlationId": {
        "bsonType": ["string", "null"],
        "maxLength": 100,
        "description": "Links entries to business transactions (PAY-, REF-, OUT-, CHB- prefixes)"
      },
      "entryDate": {
        "bsonType": "date",
        "description": "Business date for accounting purposes"
      },
      "effectiveDate": {
        "bsonType": ["date", "null"]
      },
      "description": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 1000
      },
      "type": {
        "bsonType": "string",
        "enum": ["STANDARD", "ADJUSTMENT", "CLOSING", "OPENING", "REVERSAL"],
        "description": "OWASP A04 - Enum constraint for entry type"
      },
      "status": {
        "bsonType": "string",
        "enum": ["DRAFT", "POSTED", "REVERSED"],
        "description": "OWASP A04 - Enum constraint for status"
      },
      "lines": {
        "bsonType": "array",
        "minItems": 2,
        "description": "Must have at least 2 lines (debit and credit)",
        "items": {
          "bsonType": "object",
          "required": ["accountCode"],
          "properties": {
            "accountCode": {
              "bsonType": "string",
              "pattern": "^\\d{4}(-[A-Z0-9]+)?$",
              "description": "OWASP A03 - Account code format (e.g., 1021, 2010-0001)"
            },
            "debit": {
              "bsonType": ["decimal", "null"],
              "minimum": 0
            },
            "credit": {
              "bsonType": ["decimal", "null"],
              "minimum": 0
            },
            "description": {
              "bsonType": ["string", "null"],
              "maxLength": 500
            }
          }
        }
      },
      "currency": {
        "bsonType": "string",
        "enum": ["ZMW", "USD"],
        "description": "OWASP A04 - Enum constraint"
      },
      "createdBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "postedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "postedAt": {
        "bsonType": ["date", "null"]
      },
      "reversedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "reversedAt": {
        "bsonType": ["date", "null"]
      },
      "reversedByEntryId": {
        "bsonType": ["string", "null"],
        "pattern": "^[a-fA-F0-9]{24}$"
      },
      "reversalOfEntryId": {
        "bsonType": ["string", "null"],
        "pattern": "^[a-fA-F0-9]{24}$"
      },
      "metadata": {
        "bsonType": ["object", "null"]
      },
      "createdAt": {
        "bsonType": "date"
      },
      "updatedAt": {
        "bsonType": ["date", "null"]
      },
      "version": {
        "bsonType": ["long", "null"]
      }
    },
    "additionalProperties": false
  }
}
