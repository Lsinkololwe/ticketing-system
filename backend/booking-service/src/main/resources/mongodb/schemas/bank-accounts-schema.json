{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Bank Accounts Schema - OWASP Compliant",
    "description": "Organizer bank account details for receiving payouts",
    "required": [
      "organizerId",
      "organizationId",
      "accountHolderName",
      "bankName",
      "accountNumber",
      "currency",
      "status",
      "createdAt"
    ],
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "organizerId": {
        "bsonType": "string",
        "pattern": "^[a-fA-F0-9]{24}$",
        "description": "OWASP A03 - ObjectId pattern validation"
      },
      "organizationId": {
        "bsonType": "string",
        "pattern": "^[a-fA-F0-9]{24}$",
        "description": "OWASP A01 - Tenant isolation for bank account management"
      },
      "accountHolderName": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 200
      },
      "bankName": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 200
      },
      "bankCode": {
        "bsonType": ["string", "null"],
        "maxLength": 20
      },
      "branchName": {
        "bsonType": ["string", "null"],
        "maxLength": 200
      },
      "branchCode": {
        "bsonType": ["string", "null"],
        "maxLength": 20
      },
      "accountNumber": {
        "bsonType": "string",
        "pattern": "^[0-9]{10,20}$",
        "description": "OWASP A03 - Bank account number format (10-20 digits)"
      },
      "accountType": {
        "bsonType": ["string", "null"],
        "enum": ["SAVINGS", "CURRENT", "CHECKING", null]
      },
      "currency": {
        "bsonType": "string",
        "enum": ["ZMW", "USD"],
        "description": "OWASP A04 - Enum constraint"
      },
      "swiftCode": {
        "bsonType": ["string", "null"],
        "pattern": "^[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?$",
        "description": "OWASP A03 - SWIFT/BIC code format"
      },
      "isDefault": {
        "bsonType": "bool"
      },
      "isVerified": {
        "bsonType": "bool"
      },
      "verifiedAt": {
        "bsonType": ["date", "null"]
      },
      "verifiedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "status": {
        "bsonType": "string",
        "enum": ["ACTIVE", "INACTIVE", "SUSPENDED"],
        "description": "OWASP A04 - Enum constraint"
      },
      "createdAt": {
        "bsonType": "date"
      },
      "updatedAt": {
        "bsonType": ["date", "null"]
      },
      "createdBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "updatedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "version": {
        "bsonType": ["long", "null"]
      }
    },
    "additionalProperties": false
  }
}
