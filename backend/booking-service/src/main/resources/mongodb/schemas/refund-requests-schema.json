{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Refund Requests Schema - OWASP Compliant",
    "description": "Tracks refund requests for ticket purchases with full approval workflow and pawaPay integration",
    "required": [
      "ticketId",
      "ticketNumber",
      "eventId",
      "organizerId",
      "organizationId",
      "buyerId",
      "requestId",
      "refundAmount",
      "currency",
      "status",
      "requestType",
      "requestReason",
      "createdAt"
    ],
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "ticketId": {
        "bsonType": "string",
        "pattern": "^[a-fA-F0-9]{24}$",
        "description": "OWASP A03 - ObjectId pattern validation"
      },
      "ticketNumber": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "eventId": {
        "bsonType": "string",
        "pattern": "^[a-fA-F0-9]{24}$",
        "description": "OWASP A03 - ObjectId pattern validation"
      },
      "organizerId": {
        "bsonType": "string",
        "pattern": "^[a-fA-F0-9]{24}$",
        "description": "OWASP A03 - ObjectId pattern validation"
      },
      "organizationId": {
        "bsonType": "string",
        "pattern": "^[a-fA-F0-9]{24}$",
        "description": "OWASP A01 - Tenant isolation required for multi-organization refund tracking"
      },
      "buyerId": {
        "bsonType": "string",
        "pattern": "^[a-fA-F0-9]{24}$",
        "description": "OWASP A03 - ObjectId pattern validation"
      },
      "requestId": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Unique request identifier"
      },
      "refundAmount": {
        "bsonType": "decimal",
        "minimum": 0,
        "description": "OWASP A04 - Positive amount validation"
      },
      "currency": {
        "bsonType": "string",
        "enum": ["ZMW", "USD", "EUR", "GBP"],
        "description": "OWASP A04 - Enum constraint for currency"
      },
      "status": {
        "bsonType": "string",
        "enum": ["PENDING", "APPROVED", "PROCESSING", "COMPLETED", "FAILED", "REJECTED"],
        "description": "OWASP A04 - Enum constraint for status"
      },
      "requestType": {
        "bsonType": "string",
        "enum": ["CUSTOMER_REQUEST", "EVENT_CANCELLED", "DUPLICATE_CHARGE", "FRAUD", "OTHER"],
        "description": "OWASP A04 - Enum constraint for request type"
      },
      "requestReason": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 500
      },
      "additionalNotes": {
        "bsonType": ["string", "null"],
        "maxLength": 2000
      },
      "supportingDocuments": {
        "bsonType": ["string", "null"],
        "maxLength": 500
      },
      "pawaPayRefundId": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "pawaPayDepositId": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "providerTransactionId": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "isAutomatic": {
        "bsonType": "bool"
      },
      "requestedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "requestedAt": {
        "bsonType": ["date", "null"]
      },
      "reviewedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "reviewedAt": {
        "bsonType": ["date", "null"]
      },
      "reviewComments": {
        "bsonType": ["string", "null"],
        "maxLength": 1000
      },
      "rejectionReason": {
        "bsonType": ["string", "null"],
        "maxLength": 500
      },
      "paymentReference": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "refundTransactionId": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "processedAt": {
        "bsonType": ["date", "null"]
      },
      "processedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "originalTicketPrice": {
        "bsonType": ["decimal", "null"],
        "minimum": 0
      },
      "processingFee": {
        "bsonType": ["decimal", "null"],
        "minimum": 0
      },
      "netRefundAmount": {
        "bsonType": ["decimal", "null"],
        "minimum": 0
      },
      "originalPaymentMethod": {
        "bsonType": ["string", "null"],
        "maxLength": 50
      },
      "originalPaymentTransactionId": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "history": {
        "bsonType": ["array", "null"],
        "items": {
          "bsonType": "object",
          "properties": {
            "action": {
              "bsonType": "string"
            },
            "performedBy": {
              "bsonType": "string"
            },
            "performedAt": {
              "bsonType": "date"
            },
            "comments": {
              "bsonType": ["string", "null"]
            },
            "previousStatus": {
              "bsonType": ["string", "null"]
            },
            "newStatus": {
              "bsonType": ["string", "null"]
            },
            "metadata": {
              "bsonType": ["object", "null"]
            }
          }
        }
      },
      "createdAt": {
        "bsonType": "date"
      },
      "updatedAt": {
        "bsonType": ["date", "null"]
      },
      "createdBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "updatedBy": {
        "bsonType": ["string", "null"],
        "maxLength": 100
      },
      "version": {
        "bsonType": ["long", "null"],
        "description": "Optimistic locking version"
      }
    },
    "additionalProperties": false
  }
}
