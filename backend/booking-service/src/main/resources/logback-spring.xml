<?xml version="1.0" encoding="UTF-8"?>
<!--
  PCI DSS Compliant Logging Configuration

  This configuration implements PCI DSS requirements for payment logging:
  - Requirement 10.2: Log all access to cardholder data
  - Requirement 10.3: Include who, what, when, where, result
  - Requirement 10.5: Secure audit trails

  Appenders:
  - CONSOLE: Standard application logs
  - APPLICATION_FILE: Rolling application logs
  - AUDIT_FILE: Payment audit trail (separate file)
  - SECURITY_FILE: Security events (separate file)
-->
<configuration>

    <!-- Properties from Spring application.yml -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="booking-service"/>

    <!-- Log patterns with correlation ID and transaction ID -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId:-}] [%X{transactionId:-}] %logger{36} - %msg%n"/>

    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId:-}] [%X{transactionId:-}] %logger{36} - %msg%n"/>

    <property name="AUDIT_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} | %X{correlationId:-} | %X{transactionId:-} | %msg%n"/>

    <!-- Log file paths -->
    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>

    <!-- ========================================================================
         CONSOLE APPENDER (Development)
         ======================================================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========================================================================
         APPLICATION FILE APPENDER (Rolling)
         ======================================================================== -->
    <appender name="APPLICATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========================================================================
         AUDIT FILE APPENDER (PCI DSS Requirement 10)
         Separate file for payment audit trail
         ======================================================================== -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/audit/${APP_NAME}-audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/audit/${APP_NAME}-audit.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <!-- Retain audit logs for 1 year (PCI DSS Requirement 10.7) -->
            <maxHistory>365</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${AUDIT_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========================================================================
         SECURITY FILE APPENDER
         Separate file for security events (auth failures, IP rejections, etc.)
         ======================================================================== -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/security/${APP_NAME}-security.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/security/${APP_NAME}-security.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <!-- Retain security logs for 1 year (PCI DSS Requirement 10.7) -->
            <maxHistory>365</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${AUDIT_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========================================================================
         ASYNC WRAPPERS (for performance)
         ======================================================================== -->
    <appender name="ASYNC_APPLICATION" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="APPLICATION_FILE"/>
    </appender>

    <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <!-- Never discard audit logs -->
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="AUDIT_FILE"/>
    </appender>

    <appender name="ASYNC_SECURITY" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <!-- Never discard security logs -->
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="SECURITY_FILE"/>
    </appender>

    <!-- ========================================================================
         LOGGERS
         ======================================================================== -->

    <!-- Audit Logger - Writes to separate audit file -->
    <logger name="AUDIT" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_AUDIT"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Security Logger - Writes to separate security file -->
    <logger name="SECURITY" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_SECURITY"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Payment-related loggers (ensure sensitive data masking is applied) -->
    <logger name="com.pml.booking.infrastructure.client.PawaPayClient" level="INFO"/>
    <logger name="com.pml.booking.web.rest.PawaPayWebhookController" level="INFO"/>
    <logger name="com.pml.booking.service.PaymentAttemptService" level="INFO"/>

    <!-- Reduce noise from libraries -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="io.netty" level="WARN"/>
    <logger name="reactor" level="WARN"/>
    <logger name="io.github.resilience4j" level="INFO"/>

    <!-- ========================================================================
         ROOT LOGGER
         ======================================================================== -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_APPLICATION"/>
    </root>

    <!-- Profile-specific configuration -->
    <springProfile name="dev,local">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="prod,production">
        <root level="INFO">
            <appender-ref ref="ASYNC_APPLICATION"/>
        </root>
    </springProfile>

</configuration>
