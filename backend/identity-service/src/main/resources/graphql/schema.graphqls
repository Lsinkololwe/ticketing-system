}

# ============================================================================
# SECTION 19: MUTATION RESPONSE TYPES
# ============================================================================

# Generic mutation response
type MutationResponse {
    success: Boolean!
    message: String
    code: String
}

# User-related responses
type UserMutationResponse {
    success: Boolean!
    message: String
    user: User
}

# Organization responses
type OrganizationMutationResponse {
    success: Boolean!
    message: String
    organization: Organization
}

# Member responses
type MemberMutationResponse {
    success: Boolean!
    message: String
    member: OrganizationMember
}

# Invitation responses
type InvitationMutationResponse {
    success: Boolean!
    message: String
    invitation: TeamInvitation
}

type BulkInvitationResponse {
    success: Boolean!
    message: String
    sentCount: Int!
    failedCount: Int!
    invitations: [TeamInvitation!]
    errors: [BulkOperationError!]
}

# Event access responses
type EventAccessMutationResponse {
    success: Boolean!
    message: String
    accessGrant: EventAccessGrant
}

type BulkAccessGrantResponse {
    success: Boolean!
    message: String
    grantedCount: Int!
    failedCount: Int!
    grants: [EventAccessGrant!]
    errors: [BulkOperationError!]
}

# Ownership transfer response
type OwnershipTransferResponse {
    success: Boolean!
    message: String
    transfer: OwnershipTransferRequest
}

# Document responses
type DocumentMutationResponse {
    success: Boolean!
    message: String
    document: VerificationDocument
}

# Notification responses
type NotificationMutationResponse {
    success: Boolean!
    message: String
    notification: Notification
}

type DeviceMutationResponse {
    success: Boolean!
    message: String
    device: UserDevice
}

