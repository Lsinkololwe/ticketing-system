}


# ============================================================================
# SECTION 21: QUERY TYPE
# Tags indicate which clients should include these queries in their operations
# ============================================================================

type Query {
    # ─────────────────────────────────────────────────────────────────────
    # User Queries
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Get current authenticated user's profile
    me: User @tag(name: "mobile")

    # ADMIN - Get user by ID for user management
    user(id: ID!): User @tag(name: "admin")

    # ADMIN - User lookup by email
    userByEmail(email: String!): User @tag(name: "admin")

    # ADMIN - User lookup by phone number
    userByPhone(phoneNumber: String!): User @tag(name: "admin")

    # ADMIN - Search users with offset pagination for admin tables
    usersOffsetPagination(
        search: String
        role: UserType
        accountStatus: AccountStatus
        pagination: OffsetPaginationInput
    ): UserOffsetPage! @tag(name: "admin")

    # ADMIN - Search users with cursor pagination
    usersCursorPagination(
        search: String
        role: UserType
        accountStatus: AccountStatus
        pagination: CursorPaginationInput
    ): UserConnection! @tag(name: "admin")

    # ADMIN - User statistics for admin dashboard
    userStats: UserStats @tag(name: "admin")

    # ADMIN - Find users by role (multi-role support)
    """
    Find all users who have a specific role.
    Example: usersByRole(role: ORGANIZER) returns all users with ORGANIZER role.
    """
    usersByRole(
        role: UserType!
        activeOnly: Boolean = true
        pagination: OffsetPaginationInput
    ): UserOffsetPage! @tag(name: "admin")

    # ADMIN - Count users by role
    """
    Count users who have a specific role.
    """
    usersCountByRole(role: UserType!): Long! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Organization Queries
    # ORGANIZER - Manage own organization, ADMIN - Manage all organizations
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER/ADMIN - Get organization by ID
    organization(id: ID!): Organization @tag(name: "organizer") @tag(name: "admin")

    # ORGANIZER/ADMIN - Get organization by slug
    organizationBySlug(slug: String!): Organization @tag(name: "organizer") @tag(name: "admin")

    # ORGANIZER - Get organization by owner ID
    organizationByOwnerId(ownerId: ID!): Organization @tag(name: "organizer") @tag(name: "admin")

    # ORGANIZER - Get organizations I belong to (for dashboard switcher)
    myOrganizations: [Organization!]! @tag(name: "organizer")

    # ORGANIZER - Get organization I own
    myOwnedOrganization: Organization @tag(name: "organizer")

    # ADMIN - Search organizations with offset pagination for admin tables
    organizationsOffsetPagination(
        search: String
        status: OrganizationStatus
        verified: Boolean
        pagination: OffsetPaginationInput
    ): OrganizationOffsetPage! @tag(name: "admin")

    # ADMIN - Search organizations with cursor pagination
    organizationsCursorPagination(
        search: String
        status: OrganizationStatus
        verified: Boolean
        pagination: CursorPaginationInput
    ): OrganizationConnection! @tag(name: "admin")

    # ORGANIZER - Check if slug is available
    isSlugAvailable(slug: String!): Boolean! @tag(name: "organizer")

    # ADMIN - Count organizations by status
    organizationCount(status: OrganizationStatus): Long! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Team Member Queries
    # ORGANIZER - Team management for organization owners/admins
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Get organization members with offset pagination
    organizationMembersOffsetPagination(
        organizationId: ID!
        role: OrganizationRole
        status: MemberStatus
        pagination: OffsetPaginationInput
    ): OrganizationMemberOffsetPage! @tag(name: "organizer")

    # ORGANIZER - Get organization members with cursor pagination
    organizationMembersCursorPagination(
        organizationId: ID!
        role: OrganizationRole
        status: MemberStatus
        pagination: CursorPaginationInput
    ): OrganizationMemberConnection! @tag(name: "organizer")

    # ORGANIZER - Get specific member
    organizationMember(organizationId: ID!, userId: ID!): OrganizationMember @tag(name: "organizer")

    # ORGANIZER - Get my membership in an organization
    myOrganizationMembership(organizationId: ID!): OrganizationMember @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Team Invitation Queries
    # ORGANIZER - Team invitation management
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Get pending invitations for organization with offset pagination
    pendingInvitationsOffsetPagination(
        organizationId: ID!
        pagination: OffsetPaginationInput
    ): TeamInvitationOffsetPage! @tag(name: "organizer")

    # ORGANIZER - Get pending invitations with cursor pagination
    pendingInvitationsCursorPagination(
        organizationId: ID!
        pagination: CursorPaginationInput
    ): TeamInvitationConnection! @tag(name: "organizer")

    # PUBLIC - Get invitation by token (for acceptance page - anyone with link)
    invitationByToken(token: String!): TeamInvitation

    # ORGANIZER - Get my pending invitations (invites sent to me)
    myPendingInvitations: [TeamInvitation!]! @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Event Access Queries
    # ORGANIZER - Event-level access control for team members
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Get event access grant by ID
    eventAccessGrant(id: ID!): EventAccessGrant @tag(name: "organizer")

    # ORGANIZER - Get event access grants for an event with offset pagination
    eventAccessGrantsOffsetPagination(
        eventId: ID!
        status: AccessGrantStatus
        pagination: OffsetPaginationInput
    ): EventAccessGrantOffsetPage! @tag(name: "organizer")

    # ORGANIZER - Get event access grants with cursor pagination
    eventAccessGrantsCursorPagination(
        eventId: ID!
        status: AccessGrantStatus
        pagination: CursorPaginationInput
    ): EventAccessGrantConnection! @tag(name: "organizer")

    # ORGANIZER - Get user's access to a specific event
    userEventAccess(userId: ID!, eventId: ID!): EventAccessGrant @tag(name: "organizer")

    # ORGANIZER - Get my access to a specific event
    myEventAccess(eventId: ID!): EventAccessGrant @tag(name: "organizer")

    # ORGANIZER - Get all my event access grants
    myEventAccessGrants: [EventAccessGrant!]! @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Ownership Transfer Queries
    # ORGANIZER - Organization ownership transfer
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Get ownership transfer by ID
    ownershipTransfer(id: ID!): OwnershipTransferRequest @tag(name: "organizer")

    # ORGANIZER - Get ownership transfer by token
    ownershipTransferByToken(token: String!): OwnershipTransferRequest @tag(name: "organizer")

    # ORGANIZER - Get pending ownership transfer for organization
    pendingOwnershipTransfer(organizationId: ID!): OwnershipTransferRequest @tag(name: "organizer")

    # ORGANIZER - Get all transfers for an organization
    ownershipTransfers(organizationId: ID!): [OwnershipTransferRequest!]! @tag(name: "organizer")

    # ORGANIZER - Get my pending ownership transfer requests (where I'm the new owner)
    myPendingOwnershipTransfers: [OwnershipTransferRequest!]! @tag(name: "organizer")

    # ORGANIZER - Check if organization has pending transfer
    hasPendingOwnershipTransfer(organizationId: ID!): Boolean! @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Permission Queries
    # ORGANIZER - Permission checks for UI rendering
    # ─────────────────────────────────────────────────────────────────────
    # ADMIN - Get permission by ID
    permission(id: ID!): Permission @tag(name: "admin")

    # ADMIN - Get permission by name
    permissionByName(name: String!): Permission @tag(name: "admin")

    # ADMIN - Get all active permissions
    permissions: [Permission!]! @tag(name: "admin")

    # ADMIN - Get permissions by category
    permissionsByCategory(category: String!): [Permission!]! @tag(name: "admin")

    # ADMIN - Get permissions assigned to a role
    rolePermissions(roleId: String!): [Permission!]! @tag(name: "admin")

    # Get current user's permissions based on their JWT roles
    currentUserPermissions: [String!]!

    # ORGANIZER - Check if user has permission
    hasOrganizationPermission(organizationId: ID!, permission: String!): Boolean! @tag(name: "organizer")
    hasEventPermission(eventId: ID!, permission: String!): Boolean! @tag(name: "organizer")

    # ORGANIZER - Get my role in organization
    myOrganizationRole(organizationId: ID!): OrganizationRole @tag(name: "organizer")

    # ORGANIZER - Get my role for event
    myEventRole(eventId: ID!): EventRole @tag(name: "organizer")

    # ORGANIZER - Get my effective permissions
    myEffectivePermissions(
        organizationId: ID
        eventId: ID
    ): EffectivePermissions! @tag(name: "organizer")

    # ADMIN - Get all permissions with optional scope filter
    allPermissions(scope: PermissionScope): [Permission!]! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # ─────────────────────────────────────────────────────────────────────
    # Organization Queries (Approval Queue)
    # ADMIN - Organization approval queue and management
    # ─────────────────────────────────────────────────────────────────────
    # ADMIN - Get organization applications with offset pagination for admin queue
    organizationApplicationsOffsetPagination(
        status: OrganizationStatus
        pagination: OffsetPaginationInput
    ): OrganizationApplicationOffsetPage! @tag(name: "admin")

    # ADMIN - Get organization applications with cursor pagination
    organizationApplicationsCursorPagination(
        status: OrganizationStatus
        pagination: CursorPaginationInput
    ): OrganizationApplicationConnection! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Verification Document Queries
    # ORGANIZER - Own documents, ADMIN - All documents
    # ─────────────────────────────────────────────────────────────────────
    # Get verification document by ID
    verificationDocument(id: ID!): VerificationDocument

    # ORGANIZER - Get my verification documents
    myVerificationDocuments(status: DocumentStatus): [VerificationDocument!]! @tag(name: "organizer")

    # ADMIN - Get documents for organization
    verificationDocuments(organizationId: ID!, status: DocumentStatus): [VerificationDocument!]! @tag(name: "admin")

    # ADMIN - Get pending documents queue
    pendingVerificationDocuments: [VerificationDocument!]! @tag(name: "admin")

    # ORGANIZER - Get document by type for organizer
    myVerificationDocumentByType(documentType: String!): VerificationDocument @tag(name: "organizer")

    # ORGANIZER - Count my documents
    myVerificationDocumentCount: Long! @tag(name: "organizer")

    # ORGANIZER - Count my approved documents
    myApprovedDocumentCount: Long! @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Notification Queries
    # MOBILE - User notification management
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Get my notifications with offset pagination
    myNotificationsOffsetPagination(
        type: NotificationType
        status: NotificationStatus
        pagination: OffsetPaginationInput
    ): NotificationOffsetPage! @tag(name: "mobile")

    # MOBILE - Get my notifications with cursor pagination (mobile/infinite scroll)
    myNotificationsCursorPagination(
        type: NotificationType
        status: NotificationStatus
        pagination: CursorPaginationInput
    ): NotificationConnection! @tag(name: "mobile")

    # MOBILE - Get unread notification count (for badge)
    unreadNotificationCount: Int! @tag(name: "mobile")

    # MOBILE - Get my notification preferences
    myNotificationPreferences: NotificationPreferences @tag(name: "mobile")

    # ─────────────────────────────────────────────────────────────────────
    # Device Queries
    # MOBILE - Device management for push notifications
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Get my registered devices
    myDevices: [UserDevice!]! @tag(name: "mobile")

    # ─────────────────────────────────────────────────────────────────────
    # Event Reminder Queries
    # MOBILE - Event reminder management
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Get my event reminders
    myEventReminders(eventId: ID): [EventReminder!]! @tag(name: "mobile")

    # ─────────────────────────────────────────────────────────────────────
    # Statistics Queries
    # ORGANIZER - Own stats, ADMIN - Platform stats
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER/ADMIN - Get organizer statistics
    organizerStatistics(organizerId: ID!): OrganizerStatistics @tag(name: "organizer") @tag(name: "admin")

    # ADMIN - Get platform statistics (admin dashboard)
    platformStatistics: PlatformStatistics @tag(name: "admin")

    # ORGANIZER - Get team statistics for organization
    teamStatistics(organizationId: ID!): TeamStatistics @tag(name: "organizer")
}

# ============================================================================
# SECTION 22: MUTATION TYPE
# Tags indicate which clients should include these mutations in their operations
# ============================================================================

type Mutation {
    # ─────────────────────────────────────────────────────────────────────
    # Authentication - Core auth operations
    # ─────────────────────────────────────────────────────────────────────
    # Login with email and password
    login(email: String!, password: String!): AuthPayload!

    # Register a new user
    register(input: RegisterInput!): User!

    # Refresh access token using refresh token
    refreshToken(refreshToken: String!): AuthPayload!

    # Logout and invalidate session
    logout: Boolean!

    # Validate a token and get its claims
    validateToken(token: String!): TokenValidation!

    # ─────────────────────────────────────────────────────────────────────
    # User Management
    # MOBILE - Self-service profile management
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Update my profile
    updateMyProfile(input: UpdateUserInput!): UserMutationResponse! @tag(name: "mobile")

    # MOBILE - Two-factor authentication setup
    setupTwoFactor(input: SetupTwoFactorInput!): TwoFactorSetupResponse! @tag(name: "mobile")
    verifyTwoFactor(input: VerifyTwoFactorInput!): MutationResponse! @tag(name: "mobile")
    disableTwoFactor(confirmationCode: String!): MutationResponse! @tag(name: "mobile")

    # MOBILE - Social login and account linking
    socialAuth(input: SocialAuthInput!): AuthPayload! @tag(name: "mobile")
    linkSocialAccount(input: SocialAuthInput!): MutationResponse! @tag(name: "mobile")
    unlinkSocialAccount(provider: SocialProvider!): MutationResponse! @tag(name: "mobile")

    # MOBILE - Account deletion (GDPR)
    requestAccountDeletion(input: RequestAccountDeletionInput!): MutationResponse! @tag(name: "mobile")
    cancelAccountDeletion: MutationResponse! @tag(name: "mobile")

    # ADMIN - User management
    createUser(input: CreateUserInput!): UserMutationResponse! @tag(name: "admin")
    updateUser(id: ID!, input: UpdateUserInput!): UserMutationResponse! @tag(name: "admin")
    suspendUser(id: ID!, reason: String!): MutationResponse! @tag(name: "admin")
    unsuspendUser(id: ID!): MutationResponse! @tag(name: "admin")
    lockUser(id: ID!, reason: String!): MutationResponse! @tag(name: "admin")
    unlockUser(id: ID!): MutationResponse! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Role Management (Multi-Role Support)
    # ADMIN - Only admins can modify user roles
    # ─────────────────────────────────────────────────────────────────────
    """
    Add a role to a user.
    A user can have multiple roles (e.g., CUSTOMER + ORGANIZER).
    The CUSTOMER role is the base role that all users have.
    """
    addUserRole(userId: ID!, role: UserType!): UserMutationResponse! @tag(name: "admin")

    """
    Remove a role from a user.
    Note: The CUSTOMER role cannot be removed as it is the base role.
    """
    removeUserRole(userId: ID!, role: UserType!): UserMutationResponse! @tag(name: "admin")

    """
    Set all roles for a user (replaces existing roles).
    The roles set must include CUSTOMER.
    """
    setUserRoles(userId: ID!, roles: [UserType!]!): UserMutationResponse! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Progressive Onboarding (Industry Standard)
    # ─────────────────────────────────────────────────────────────────────
    # Organization Onboarding (Approval-Based)
    # APPROVAL FLOW: DRAFT → PENDING_REVIEW → APPROVED/CHANGES_REQUESTED/REJECTED
    # User can create DRAFT events during approval process
    # ─────────────────────────────────────────────────────────────────────

    """
    Apply to become an organizer.
    Creates a new organization in DRAFT status.
    User must fill in business details and submit for approval.
    """
    applyToBeOrganizer(input: OrganizationApplicationInput!): Organization! @tag(name: "organizer")

    """
    Update organization application details.
    Only allowed when status is DRAFT or CHANGES_REQUESTED.
    """
    updateOrganizationApplication(id: ID!, input: OrganizationApplicationInput!): Organization @tag(name: "organizer")

    """
    Submit organization application for admin review.
    Changes status from DRAFT/CHANGES_REQUESTED to PENDING_REVIEW.
    """
    submitOrganizationForReview(id: ID!): Organization @tag(name: "organizer")

    """
    Get or create organization for the current user.
    If user has no organization, creates one in DRAFT status.
    """
    getOrCreateMyOrganization: Organization! @tag(name: "organizer")

    """
    Upgrade an individual organization to a business organization.
    Requires the organization to be owned by the current user.
    """
    upgradeToBusinessOrganization(organizationId: ID!, businessName: String!): Organization @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Organization Approval (Admin)
    # ADMIN - Organization approval workflow
    # ─────────────────────────────────────────────────────────────────────

    """
    Approve an organization application.
    Changes status from PENDING_REVIEW to APPROVED.
    Organization can now publish events.
    """
    approveOrganization(id: ID!): Organization @tag(name: "admin")

    """
    Request changes to an organization application.
    Changes status from PENDING_REVIEW to CHANGES_REQUESTED.
    User can update details and resubmit.
    """
    requestOrganizationChanges(id: ID!, reason: String!): Organization @tag(name: "admin")

    """
    Reject an organization application.
    Changes status to REJECTED.
    """
    rejectOrganization(id: ID!, reason: String!): Organization @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Organization Management
    # ORGANIZER - Organization settings management
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Update organization (owner/admin only)
    updateOrganization(
        id: ID!
        input: UpdateOrganizationInput!
    ): Organization @tag(name: "organizer")

    # ORGANIZER - Update organization settings
    updateOrganizationSettings(
        id: ID!
        input: UpdateOrganizationSettingsInput!
    ): Organization @tag(name: "organizer")

    # ADMIN - Suspend organization
    suspendOrganization(id: ID!, reason: String!): Organization @tag(name: "admin")

    # ADMIN - Unsuspend organization
    unsuspendOrganization(id: ID!): Organization @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Payout Configuration (PCI-DSS Compliant)
    # ORGANIZER - Configure payout accounts for receiving event revenue
    # ─────────────────────────────────────────────────────────────────────

    """
    Update payout configuration (method, schedule, minimum amount).
    AUTHORIZATION: Only organization OWNER can modify payout config.
    SECURITY: All changes are audit logged with IP address and user agent.
    """
    updatePayoutConfig(
        organizationId: ID!
        input: UpdatePayoutConfigInput!
    ): Organization @tag(name: "organizer")

    """
    Set bank account for payouts.
    AUTHORIZATION: Only organization OWNER can set bank account.
    SECURITY:
    - Account numbers are encrypted at rest (AES-256-GCM)
    - Input is validated (10-16 digits for Zambian banks)
    - SWIFT codes validated (8 or 11 alphanumeric characters)
    - Account holder name validated (letters, spaces, hyphens, apostrophes only)
    - All changes audit logged (with masked account numbers)
    COMPLIANCE: PCI-DSS compliant encryption and audit trail.
    """
    setBankAccount(
        organizationId: ID!
        input: SetBankAccountInput!
    ): Organization @tag(name: "organizer")

    """
    Set mobile money account for payouts.
    AUTHORIZATION: Only organization OWNER can set mobile money account.
    SECURITY:
    - Phone numbers validated in E.164 format (+260XXXXXXXXX)
    - Validated against Zambian mobile prefixes (MTN, Airtel, Zamtel)
    - Phone numbers masked for display (show prefix + last 4 digits)
    - All changes audit logged
    """
    setMobileMoneyAccount(
        organizationId: ID!
        input: SetMobileMoneyAccountInput!
    ): Organization @tag(name: "organizer")

    """
    Verify payout account (admin only).
    AUTHORIZATION: Only ADMIN or FINANCE role can verify accounts.
    SECURITY:
    - Verification status change is audit logged
    - Only verified accounts can receive payouts
    - Verification can be revoked if fraud detected
    """
    verifyPayoutAccount(
        organizationId: ID!
        verified: Boolean!
    ): Organization @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Team Management
    # ORGANIZER - Team invitation and management
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Invite team member (matches resolver signature)
    inviteTeamMember(organizationId: ID!, input: InviteMemberInput!): TeamInvitation @tag(name: "organizer")

    # ORGANIZER - Bulk invite team members
    bulkInviteTeamMembers(organizationId: ID!, invitations: [InviteMemberInput!]!): [TeamInvitation!] @tag(name: "organizer")

    # ORGANIZER - Resend invitation
    resendInvitation(invitationId: ID!): TeamInvitation @tag(name: "organizer")

    # ORGANIZER - Revoke invitation
    revokeInvitation(invitationId: ID!): TeamInvitation @tag(name: "organizer")

    # ORGANIZER - Accept invitation (by invitee)
    acceptInvitation(token: String!): OrganizationMember @tag(name: "organizer")

    # ORGANIZER - Decline invitation (by invitee)
    declineInvitation(token: String!): TeamInvitation @tag(name: "organizer")

    # ORGANIZER - Update member role
    updateMemberRole(memberId: ID!, input: UpdateMemberRoleInput!): OrganizationMember @tag(name: "organizer")

    # ORGANIZER - Remove member
    removeMember(memberId: ID!, reason: String): Boolean! @tag(name: "organizer")

    # ORGANIZER - Suspend member
    suspendMember(memberId: ID!, reason: String): OrganizationMember @tag(name: "organizer")

    # ORGANIZER - Reactivate member
    reactivateMember(memberId: ID!): OrganizationMember @tag(name: "organizer")

    # ORGANIZER - Leave organization (self-removal)
    leaveOrganization(organizationId: ID!): Boolean! @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Ownership Transfer
    # ORGANIZER - Organization ownership transfer workflow
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Initiate ownership transfer (current owner)
    initiateOwnershipTransfer(organizationId: ID!, newOwnerId: ID!, reason: String): OwnershipTransferRequest @tag(name: "organizer")

    # ORGANIZER - Cancel ownership transfer (current owner)
    cancelOwnershipTransfer(organizationId: ID!): OwnershipTransferRequest @tag(name: "organizer")

    # ORGANIZER - Accept ownership transfer (new owner)
    acceptOwnershipTransfer(token: String!, confirmationCode: String!): OwnershipTransferRequest @tag(name: "organizer")

    # ORGANIZER - Decline ownership transfer (new owner)
    declineOwnershipTransfer(token: String!): OwnershipTransferRequest @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Event Access Management
    # ORGANIZER - Event-level access control for team members
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Create event owner (internal)
    createEventOwner(eventId: ID!, organizationId: ID!): EventAccessGrant @tag(name: "internal")

    # ORGANIZER - Grant event access
    grantEventAccess(eventId: ID!, organizationId: ID!, userId: ID!, role: EventRole!, customPermissions: [String!], reason: String, expiresAt: DateTime): EventAccessGrant @tag(name: "organizer")

    # ORGANIZER - Bulk grant event access
    bulkGrantEventAccess(eventId: ID!, organizationId: ID!, grants: [EventAccessGrantInput!]!): [EventAccessGrant!] @tag(name: "organizer")

    # ORGANIZER - Update event access
    updateEventAccess(accessId: ID!, newRole: EventRole, customPermissions: [String!], expiresAt: DateTime): EventAccessGrant @tag(name: "organizer")

    # ORGANIZER - Revoke event access
    revokeEventAccess(accessId: ID!, reason: String): EventAccessGrant @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Notification Management
    # MOBILE - User notification management
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Mark notification as read
    markNotificationRead(notificationId: ID!): Notification @tag(name: "mobile")

    # MOBILE - Mark all notifications as read
    markAllNotificationsRead: Int! @tag(name: "mobile")

    # MOBILE - Delete notification
    deleteNotification(notificationId: ID!): Boolean! @tag(name: "mobile")

    # MOBILE - Update notification preferences
    updateNotificationPreferences(input: UpdateNotificationPreferencesInput!): NotificationPreferences @tag(name: "mobile")

    # ADMIN - Send notification (admin/system)
    sendNotification(input: SendNotificationInput!): Notification @tag(name: "admin")

    # ADMIN - Send bulk notification
    sendBulkNotification(userIds: [ID!]!, input: SendNotificationInput!): Int! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Device Management
    # MOBILE - Push notification device management
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Register device for push notifications
    registerDevice(input: RegisterDeviceInput!): UserDevice @tag(name: "mobile")

    # MOBILE - Unregister device
    unregisterDevice(deviceId: ID!): Boolean! @tag(name: "mobile")

    # ─────────────────────────────────────────────────────────────────────
    # Event Reminder Management
    # MOBILE - Event reminder management
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Set event reminder
    setEventReminder(input: SetEventReminderInput!): EventReminder @tag(name: "mobile")

    # MOBILE - Cancel event reminder
    cancelEventReminder(reminderId: ID!): Boolean! @tag(name: "mobile")

    # ─────────────────────────────────────────────────────────────────────
    # Organization Management (additional)
    # ─────────────────────────────────────────────────────────────────────
    # ADMIN - Update organization status
    updateOrganizationStatus(id: ID!, status: OrganizationStatus!): Organization @tag(name: "admin")

    # ORGANIZER - Transfer ownership (alternative method)
    transferOrganizationOwnership(organizationId: ID!, newOwnerId: ID!): OrganizationMember @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # NOTE: Organizer Profile mutations have been merged into Organization
    # See Organization Onboarding mutations:
    # - applyToBeOrganizer
    # - updateOrganizationApplication
    # - submitOrganizationForReview
    # - approveOrganization
    # - requestOrganizationChanges
    # - rejectOrganization
    # ─────────────────────────────────────────────────────────────────────

    # ─────────────────────────────────────────────────────────────────────
    # Permission Management
    # ─────────────────────────────────────────────────────────────────────
    # ADMIN - Create permission
    createPermission(name: String!, description: String, category: String): Permission @tag(name: "admin")

    # ADMIN - Update permission
    updatePermission(id: ID!, name: String, description: String, category: String): Permission @tag(name: "admin")

    # ADMIN - Delete permission
    deletePermission(id: ID!): Boolean! @tag(name: "admin")

    # ADMIN - Assign permission to role
    assignPermissionToRole(roleId: ID!, permissionId: ID!): Boolean! @tag(name: "admin")

    # ADMIN - Remove permission from role
    removePermissionFromRole(roleId: ID!, permissionId: ID!): Boolean! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Phone OTP Authentication
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Request phone OTP
    requestPhoneOtp(phoneNumber: String!, channel: String): OtpRequestResponse! @tag(name: "mobile")

    # MOBILE - Verify phone OTP
    verifyPhoneOtp(phoneNumber: String!, otp: String!): PhoneAuthPayload! @tag(name: "mobile")

    # ─────────────────────────────────────────────────────────────────────
    # User Profile & Verification
    # ─────────────────────────────────────────────────────────────────────
    # MOBILE - Send email verification
    sendEmailVerification: Boolean! @tag(name: "mobile")

    # MOBILE - Verify email
    verifyEmail(token: String!): User @tag(name: "mobile")

    # MOBILE - Sync email verification status
    syncEmailVerificationStatus: User @tag(name: "mobile")

    # MOBILE - Update profile
    updateProfile(input: JSON!): User @tag(name: "mobile")

    # MOBILE - Change password
    changePassword(oldPassword: String!, newPassword: String!): Boolean! @tag(name: "mobile")

    # MOBILE - Reset password
    resetPassword(email: String!): Boolean! @tag(name: "mobile")

    # MOBILE - Send phone verification
    sendPhoneVerification: Boolean! @tag(name: "mobile")

    # MOBILE - Verify phone
    verifyPhone(code: String!): User @tag(name: "mobile")

    # ADMIN - Deactivate user
    deactivateUser(id: ID!): Boolean! @tag(name: "admin")

    # ADMIN - Activate user
    activateUser(id: ID!): Boolean! @tag(name: "admin")

    # ─────────────────────────────────────────────────────────────────────
    # Verification Document Management
    # Secure file upload workflow with OWASP compliance
    # ─────────────────────────────────────────────────────────────────────
    # ORGANIZER - Upload verification document (with file validation)
    uploadVerificationDocument(input: UploadVerificationDocumentInput!): VerificationDocumentUploadResponse! @tag(name: "organizer")

    # ORGANIZER - Request presigned upload URL (alternative flow)
    requestDocumentUploadUrl(input: RequestUploadUrlInput!): DocumentUploadUrlResponse! @tag(name: "organizer")

    # ADMIN - Approve verification document
    approveVerificationDocument(documentId: ID!): VerificationDocument @tag(name: "admin")

    # ADMIN - Reject verification document
    rejectVerificationDocument(documentId: ID!, reason: String!): VerificationDocument @tag(name: "admin")

    # ORGANIZER - Delete verification document
    deleteVerificationDocument(documentId: ID!): Boolean! @tag(name: "organizer")

    # ─────────────────────────────────────────────────────────────────────
    # Keycloak Sync (Internal)
    # ─────────────────────────────────────────────────────────────────────
    # ADMIN - Sync user from Keycloak
    syncUserFromKeycloak(userId: ID!): User @tag(name: "admin")

    # ADMIN - Full sync all users
    syncAllUsersFromKeycloak: Boolean! @tag(name: "admin")
}

