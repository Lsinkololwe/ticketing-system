{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/playwright",
    "allowJs": true,
    "types": [
      "@playwright/test",
      "node"
    ],
    "sourceMap": false
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "playwright.config.ts",
    "e2e/**/*.spec.ts",
    "e2e/**/*.spec.tsx",
    "**/*.d.ts"
  ],
  "exclude": [
    "out-tsc",
    "test-output",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "./tsconfig.e2e.json"
    }
  ]
}
