{
  "name": "@pml.tickets/admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/admin/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/admin"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/admin"
        },
        "production": {}
      }
    },
    "dev": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "@pml.tickets/admin:build",
        "dev": true,
        "port": 3030
      },
      "configurations": {
        "development": {
          "buildTarget": "@pml.tickets/admin:build:development",
          "dev": true,
          "port": 3030
        },
        "production": {
          "buildTarget": "@pml.tickets/admin:build:production",
          "dev": false
        }
      }
    },
    "start": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "@pml.tickets/admin:build",
        "port": 3030
      },
      "configurations": {
        "development": {
          "buildTarget": "@pml.tickets/admin:build:development"
        },
        "production": {
          "buildTarget": "@pml.tickets/admin:build:production"
        }
      }
    }
  }
}
