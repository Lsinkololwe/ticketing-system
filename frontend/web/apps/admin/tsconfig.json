{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noEmit": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@components": [
        "./src/components"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@lib": [
        "./src/lib"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@types": [
        "./src/types"
      ],
      "@types/*": [
        "./src/types/*"
      ],
      "@hooks": [
        "./src/hooks"
      ],
      "@hooks/*": [
        "./src/hooks/*"
      ],
      "@utils": [
        "./src/utils"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@contexts": [
        "./src/contexts"
      ],
      "@contexts/*": [
        "./src/contexts/*"
      ],
      "@graphql": [
        "./src/graphql"
      ],
      "@graphql/*": [
        "./src/graphql/*"
      ],
      "@generated": [
        "./src/types/generated/graphql"
      ],
      "@generated/*": [
        "./src/types/generated/*"
      ],
      "@shared": [
        "../../libs/shared/src/index.ts"
      ],
      "@shared/*": [
        "../../libs/shared/src/*"
      ],
      "@pml.tickets/shared": [
        "../../libs/shared/src/index.ts"
      ],
      "@pml.tickets/shared/*": [
        "../../libs/shared/src/*"
      ]
    },
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": [
    "../../apps/admin/.next/types/**/*.ts",
    "../../dist/apps/admin/.next/types/**/*.ts",
    "next-env.d.ts",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "out-tsc",
    "dist",
    "node_modules",
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    ".next"
  ],
  "references": [
    {
      "path": "../../libs/shared"
    }
  ]
}
