# Environment Configuration
# Copy this file to .env and fill in the values

# GraphQL Endpoint (Apollo Router)
GRAPHQL_ENDPOINT=http://localhost:4001/

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8084
KEYCLOAK_REALM=myticketzm
KEYCLOAK_CLIENT_ID=myticketzm-mobile
KEYCLOAK_REDIRECT_SCHEME=com.ticketing.mobile
